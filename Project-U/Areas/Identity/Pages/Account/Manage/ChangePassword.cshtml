@page
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model ChangePasswordModel
@{
    ViewData["Title"] = Localizer["Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🔒 @Localizer["Title"]</h2>
    <a asp-controller="Settings" asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form id="change-password-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.OldPassword" class="form-label">🔑 @Localizer["OldPassword"]</label>
                        <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" placeholder="@Localizer["OldPasswordPlaceholder"]" />
                        <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.NewPassword" class="form-label">🔐 @Localizer["NewPassword"]</label>
                        <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["NewPasswordPlaceholder"]" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.ConfirmPassword" class="form-label">✅ @Localizer["ConfirmPassword"]</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="@Localizer["ConfirmPasswordPlaceholder"]" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">💾 @Localizer["Save"]</button>
                        <a asp-controller="Settings" asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}