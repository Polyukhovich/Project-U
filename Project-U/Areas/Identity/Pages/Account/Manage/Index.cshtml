@page
@model IndexModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>✏️ @Localizer["Title"]</h2>
    <a asp-controller="Settings" asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">📧 @Localizer["Email"]</label>
                        <input asp-for="Username" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.FirstName" class="form-label">👤 @Localizer["FirstName"]</label>
                        <input asp-for="Input.FirstName" class="form-control" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.LastName" class="form-label">👤 @Localizer["LastName"]</label>
                        <input asp-for="Input.LastName" class="form-control" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">💾 @Localizer["Save"]</button>
                        <a asp-controller="Settings" asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}