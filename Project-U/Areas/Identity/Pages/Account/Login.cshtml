@page
@model LoginModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Project U — @Localizer["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/sidebar.css" />
    <style>
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #1a1a2e;
        }

        .login-wrapper {
            width: 100%;
            max-width: 420px;
            padding: 20px;
        }

        .login-card {
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1);
            border: none;
            overflow: hidden;
        }

        .login-header {
            background: linear-gradient(135deg, #1a1a2e, #6c5ce7);
            padding: 30px;
            text-align: center;
            color: white;
        }

            .login-header h1 {
                font-size: 2rem;
                font-weight: bold;
                margin: 0;
                color: white;
            }

            .login-header p {
                opacity: 0.8;
                margin: 5px 0 0;
                color: white;
            }

        .login-body {
            padding: 30px;
            background: var(--card-bg);
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card card">
            <div class="login-header">
                <div style="font-size: 3rem;">🎓</div>
                <h1>Project U</h1>
                <p>@Localizer["Subtitle"]</p>
            </div>
            <div class="login-body">
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">📧 @Localizer["Email"]</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username"
                               placeholder="your@email.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Password" class="form-label">🔑 @Localizer["Password"]</label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                               placeholder="••••••••" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            @Localizer["RememberMe"]
                        </label>
                    </div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg">
                        🚀 @Localizer["Login"]
                    </button>
                    <div class="text-center mt-3">
                        <small class="text-muted">@Localizer["ForgotPassword"]</small>
                    </div>
                </form>
            </div>
        </div>
        <div class="text-center mt-3 text-muted small">
            © 2026 Project U
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>