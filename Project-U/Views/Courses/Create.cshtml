@model ProjectU.Core.Models.Course
@{
    ViewData["Title"] = "Створити курс";
}

<h2>Створити курс</h2>

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Прихований TeacherId — поточний викладач -->
            <input type="hidden" name="TeacherId" value="@ViewData["CurrentUserId"]" />

            <div class="mb-3">
                <label class="form-label">Викладач</label>
                <input type="text" class="form-control" value="@ViewData["CurrentUserName"]" disabled />
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Назва курсу</label>
                <input asp-for="Name" class="form-control" placeholder="Наприклад: Сучасні Інтернет Технології" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GroupId" class="form-label">Група</label>
                <select asp-for="GroupId" asp-items="ViewBag.GroupId" class="form-select">
                    <option value="">— Оберіть групу —</option>
                </select>
                <span asp-validation-for="GroupId" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Створити</button>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}