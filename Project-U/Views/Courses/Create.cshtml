@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Course
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>➕ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" name="TeacherId" value="@ViewBag.CurrentUserId" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">@Localizer["CourseName"]</label>
                        <input asp-for="Name" class="form-control" placeholder="@Localizer["CourseNamePlaceholder"]" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mb-3">
                            <label class="form-label">👨‍🏫 @Localizer["MainTeacher"]</label>
                            <select name="TeacherId" class="form-select" required>
                                <option value="">@Localizer["SelectTeacher"]</option>
                                @foreach (var teacher in (IList<ProjectU.Core.Models.ApplicationUser>)ViewBag.AllTeachers)
                                {
                                    <option value="@teacher.Id">@teacher.FirstName @teacher.LastName</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <input type="hidden" name="TeacherId" value="@ViewBag.CurrentUserId" />
                        <div class="mb-3">
                            <label class="form-label">👨‍🏫 @Localizer["MainTeacher"]</label>
                            <input type="text" class="form-control" value="@ViewBag.CurrentUserName" disabled />
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label">@Localizer["Group"]</label>
                        <select asp-for="GroupId" asp-items="@(ViewData["GroupId"] as SelectList)" class="form-select">
                            <option value="">@Localizer["SelectGroup"]</option>
                        </select>
                        <span asp-validation-for="GroupId" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="CourseType" class="form-label">📋 @Localizer["CourseType"]</label>
                        <select asp-for="CourseType" class="form-select">
                            <option value="Exam">🎓 @Localizer["Exam"]</option>
                            <option value="Credit">✅ @Localizer["Credit"]</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">👨‍🏫 @Localizer["AdditionalTeachers"]</label>
                        @if (ViewBag.AllTeachers != null)
                        {
                            @foreach (var teacher in (IList<ProjectU.Core.Models.ApplicationUser>)ViewBag.AllTeachers)
                            {
                                @if (teacher.Id != (string)ViewBag.CurrentUserId)
                                {
                                    <div class="form-check">
                                        <input type="checkbox" name="additionalTeacherIds"
                                               value="@teacher.Id"
                                               class="form-check-input" />
                                        <label class="form-check-label">
                                            @teacher.FirstName @teacher.LastName
                                        </label>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <p class="text-muted small">@Localizer["NoOtherTeachers"]</p>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">➕ @Localizer["Create"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}