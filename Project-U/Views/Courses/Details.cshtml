@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Course
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📚 @Model.Name</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header"><strong>📋 @Localizer["Info"]</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">@Localizer["CourseName"]</dt>
                    <dd class="col-sm-7">@Model.Name</dd>

                    <dt class="col-sm-5">@Localizer["Group"]</dt>
                    <dt class="col-sm-5">@Localizer["CourseType"]</dt>
                    <dd class="col-sm-7">
                        @if (Model.CourseType == ProjectU.Core.Models.CourseType.Exam)
                        {
                            <span class="badge bg-danger">🎓 @Localizer["Exam"]</span>
                        }
                        else
                        {
                            <span class="badge bg-success">✅ @Localizer["Credit"]</span>
                        }
                    </dd>
                    <dd class="col-sm-7">
                        <span class="badge bg-secondary">@(Model.Group?.Name ?? "—")</span>
                    </dd>
                </dl>

                <hr />
                <div class="fw-bold mb-2">👨‍🏫 @Localizer["Teachers"]:</div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-primary">@Localizer["MainTeacher"]</span>
                    <span>@(Model.Teacher != null ? $"{Model.Teacher.FirstName} {Model.Teacher.LastName}" : "—")</span>
                </div>

                @if (Model.CourseTeachers != null && Model.CourseTeachers.Any())
                {
                    @foreach (var ct in Model.CourseTeachers)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="badge bg-secondary">@Localizer["Assistant"]</span>
                            <span>@(ct.Teacher != null ? $"{ct.Teacher.FirstName} {ct.Teacher.LastName}" : "—")</span>
                        </div>
                    }
                }
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
            {
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm flex-fill">✏️ @Localizer["Edit"]</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">🗑️</a>
                    }
                </div>
            }
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>🔬 @Localizer["SubmittedWorks"]</strong>
                <span class="badge bg-secondary">@(Model.LabWorks?.Count ?? 0)</span>
            </div>
            <div class="card-body p-0">
                @if (Model.LabWorks != null && Model.LabWorks.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["WorkTitle"]</th>
                                    <th>@Localizer["Student"]</th>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Status"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var work in Model.LabWorks)
                                {
                                    <tr>
                                        <td>@work.Title</td>
                                        <td>
                                            @(work.Student != null
                                                                                ? $"{work.Student.FirstName} {work.Student.LastName}"
                                                                                : "—")
                                </td>
                                <td>@work.UploadedAt.ToShortDateString()</td>
                                <td>
                                    @if (work.IsGraded)
                                            {
                                                <span class="badge bg-success">✅ @Localizer["Graded"]</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">⏳ @Localizer["Waiting"]</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <div style="font-size: 2rem;">📭</div>
                        <div>@Localizer["NoWorks"]</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>