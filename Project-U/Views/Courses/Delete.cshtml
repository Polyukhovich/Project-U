@model ProjectU.Core.Models.Course
@{
    ViewData["Title"] = "Видалити курс";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ Видалити курс</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <dl class="row mb-3">
                    <dt class="col-sm-4">Назва</dt>
                    <dd class="col-sm-8"><strong>@Model.Name</strong></dd>
                    <dt class="col-sm-4">Викладач</dt>
                    <dd class="col-sm-8">
                        @(Model.Teacher != null
                                                ? $"{Model.Teacher.FirstName} {Model.Teacher.LastName}"
                                                : "—")
                    </dd>
                    <dt class="col-sm-4">Група</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@(Model.Group?.Name ?? "—")</span>
                    </dd>
                </dl>

                @if (ViewBag.CanDelete == false)
                {
                    <div class="alert alert-danger mb-3">
                        ❌ Неможливо видалити курс <strong>@Model.Name</strong> — є здані роботи або оцінки!
                    </div>
                    <a asp-action="Index" class="btn btn-secondary w-100">← Назад</a>
                }
                else
                {
                    <div class="alert alert-warning mb-3">
                        ⚠️ Ви впевнені що хочете видалити цей курс?
                    </div>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger flex-fill">🗑️ Видалити</button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Скасувати</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>