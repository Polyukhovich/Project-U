@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Course
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <dl class="row mb-3">
                    <dt class="col-sm-4">@Localizer["CourseName"]</dt>
                    <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-4">@Localizer["Teacher"]</dt>
                    <dd class="col-sm-8">
                        @(Model.Teacher != null
                                                ? $"{Model.Teacher.FirstName} {Model.Teacher.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-4">@Localizer["Group"]</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@(Model.Group?.Name ?? "—")</span>
                    </dd>
                </dl>

                @if (ViewBag.CanDelete == false)
                {
                    <div class="alert alert-danger mb-3">
                        ❌ @Localizer["CannotDelete"]
                    </div>
                    <a asp-action="Index" class="btn btn-secondary w-100">← @Localizer["Back"]</a>
                }
                else
                {
                    <div class="alert alert-warning mb-3">
                        ⚠️ @Localizer["Warning"]
                    </div>
                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger flex-fill">🗑️ @Localizer["Delete"]</button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">@Localizer["Cancel"]</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>