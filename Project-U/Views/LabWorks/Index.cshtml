@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
    var grouped = ViewBag.GroupedLabWorks as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🔬 @Localizer["Title"]</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Student"))
    {
        <a asp-action="Create" class="btn btn-primary">➕ @Localizer["AddLabWork"]</a>
    }
</div>

@if (grouped != null && grouped.Any())
{
    @foreach (var group in grouped)
    {
        var total = (int)group.TotalCount;
        var graded = (int)group.GradedCount;
        var percent = total > 0 ? (graded * 100 / total) : 0;

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>📚 @group.CourseName</strong>
                    <span class="text-muted small ms-2">@total робіт</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <small class="text-muted">Оцінено: @graded/@total</small>
                    <div class="progress" style="width: 80px; height: 8px;">
                        <div class="progress-bar bg-success" style="width: @percent%"></div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (ProjectU.Core.Models.LabWork item in group.LabWorks)
                    {
                        var borderColor = item.IsGraded ? "#00b894" : "#fdcb6e";
                        var statusEmoji = item.IsGraded ? "✅" : "⏳";

                        <div class="col-md-6 col-lg-4 mb-3">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none d-block">
                                <div class="card h-100" style="border-top: 3px solid @borderColor; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease;"
                                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.15)'"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="mb-0">@item.Title</h6>
                                            <span style="font-size:1.3rem;">@statusEmoji</span>
                                        </div>

                                        @if (!User.IsInRole("Student"))
                                        {
                                            <div class="small mb-1">👤 @(item.Student?.Email ?? "—")</div>
                                        }

                                        <div class="small mb-1">📋 @(item.Assignment?.Title ?? "—")</div>

                                        <div class="small mb-2">📅 @item.UploadedAt.ToString("dd.MM.yyyy HH:mm")</div>

                                        @if (!string.IsNullOrEmpty(item.FileName))
                                        {
                                            <div class="small mb-2">📄 @item.FileName</div>
                                        }

                                        @if (item.IsGraded)
                                        {
                                            <span class="badge bg-success">✅ Оцінено</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">⏳ Очікує оцінки</span>
                                        }
                                    </div>
                                </div>
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <div class="mt-1">
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger w-100">🗑️</a>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info text-center p-4">
        <div style="font-size: 3rem;">📭</div>
        <div>Робіт ще немає</div>
    </div>
}