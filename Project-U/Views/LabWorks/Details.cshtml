@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🔬 @Model.Title</h2>
    <a asp-controller="Assignments" asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card" style="border-top: 4px solid @(Model.IsGraded ? "#00b894" : "#fdcb6e");">
            <div class="card-header"><strong>📋 @Localizer["Info"]</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">@Localizer["Student"]</dt>
                    <dd class="col-sm-7">
                        @(Model.Student != null
                                                ? $"{Model.Student.FirstName} {Model.Student.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-5">@Localizer["Course"]</dt>
                    <dd class="col-sm-7">@(Model.Course?.Name ?? "—")</dd>

                    <dt class="col-sm-5">@Localizer["Assignment"]</dt>
                    <dd class="col-sm-7">@(Model.Assignment?.Title ?? "—")</dd>

                    <dt class="col-sm-5">@Localizer["File"]</dt>
                    <dd class="col-sm-7">
                        @if (!string.IsNullOrEmpty(Model.FileName))
                        {
                            <span>📄 @Model.FileName</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-5">@Localizer["SubmittedAt"]</dt>
                    <dd class="col-sm-7">@Model.UploadedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-5">@Localizer["Status"]</dt>
                    <dd class="col-sm-7">
                        @{
                            var grade = ViewBag.Grade as ProjectU.Core.Models.Grade;
                            var gradeColor = grade != null ? (grade.Value >= 90 ? "#00b894" : grade.Value >= 75 ? "#0984e3" : grade.Value >= 60 ? "#fdcb6e" : "#d63031") : "";
                        }
                        @if (grade != null)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:45px;height:45px;border-radius:50%;background:@gradeColor;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:bold;color:white;">
                                    @grade.Value
                                </div>
                                <div>
                                    <div class="badge bg-success">✅ @Localizer["Graded"]</div>
                                    <div class="small text-muted">@grade.CreatedAt.ToShortDateString()</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-warning">⏳ @Localizer["Waiting"]</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2 flex-wrap">
                @if (!Model.IsGraded && (User.IsInRole("Admin") || User.IsInRole("Student")))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm flex-fill">✏️ @Localizer["Edit"]</a>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    @if (ViewBag.Grade != null)
                    {
                        <a asp-controller="Grades" asp-action="Edit" asp-route-id="@((ViewBag.Grade as ProjectU.Core.Models.Grade)!.Id)"
                           class="btn btn-outline-warning btn-sm flex-fill">✏️ @Localizer["EditGrade"]</a>
                        <a asp-controller="Grades" asp-action="Delete" asp-route-id="@((ViewBag.Grade as ProjectU.Core.Models.Grade)!.Id)"
                           class="btn btn-outline-danger btn-sm">🗑️ @Localizer["DeleteGrade"]</a>
                    }
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Student"))
                {
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">🗑️ @Localizer["Delete"]</a>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card">
            <div class="card-header"><strong>🔍 @Localizer["PlagiarismResults"]</strong></div>
            <div class="card-body p-0">
                @if (Model.PlagiarismResults != null && Model.PlagiarismResults.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["ComparedWith"]</th>
                                    <th>@Localizer["Similarity"]</th>
                                    <th>@Localizer["CheckedAt"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in Model.PlagiarismResults)
                                {
                                    var plagColor = result.SimilarityPercent > 50 ? "#d63031" : result.SimilarityPercent > 20 ? "#fdcb6e" : "#00b894";
                                    <tr>
                                        <td>@(result.ComparedWith?.Title ?? "—")</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height: 8px;">
                                                    <div class="progress-bar" style="width: @result.SimilarityPercent%; background: @plagColor;"></div>
                                                </div>
                                                <span class="badge" style="background: @plagColor;">
                                                    @result.SimilarityPercent.ToString("F1")%
                                                </span>
                                            </div>
                                            @if (result.SimilarityPercent > 50)
                                            {
                                                <small class="text-danger">@Localizer["HighPlagiarism"]</small>
                                            }
                                            else if (result.SimilarityPercent > 20)
                                            {
                                                <small class="text-warning">@Localizer["MediumPlagiarism"]</small>
                                            }
                                            else
                                            {
                                                <small class="text-success">@Localizer["LowPlagiarism"]</small>
                                            }
                                        </td>
                                        <td>@result.CheckedAt.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <div style="font-size: 2rem;">🔍</div>
                        <div>@Localizer["NoResults"]</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>