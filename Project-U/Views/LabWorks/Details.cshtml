@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = "Деталі роботи";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🔬 @Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <!-- Інформація про роботу -->
    <div class="col-md-4 mb-4">
        <div class="card" style="border-top: 4px solid @(Model.IsGraded ? "#00b894" : "#fdcb6e");">
            <div class="card-header"><strong>📋 Інформація</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5">Студент</dt>
                    <dd class="col-sm-7">
                        @(Model.Student != null
                                                ? $"{Model.Student.FirstName} {Model.Student.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-5">Курс</dt>
                    <dd class="col-sm-7">@(Model.Course?.Name ?? "—")</dd>

                    <dt class="col-sm-5">Завдання</dt>
                    <dd class="col-sm-7">@(Model.Assignment?.Title ?? "—")</dd>

                    <dt class="col-sm-5">Файл</dt>
                    <dd class="col-sm-7">
                        @if (!string.IsNullOrEmpty(Model.FileName))
                        {
                            <span>📄 @Model.FileName</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-5">Дата здачі</dt>
                    <dd class="col-sm-7">@Model.UploadedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-5">Статус</dt>
                    <dd class="col-sm-7">
                        @{
                            var grade = ViewBag.Grade as ProjectU.Core.Models.Grade;
                            var gradeColor = grade != null ? (grade.Value >= 90 ? "#00b894" : grade.Value >= 75 ? "#0984e3" : grade.Value >= 60 ? "#fdcb6e" : "#d63031") : "";
                        }
                        @if (grade != null)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <div style="width:45px;height:45px;border-radius:50%;background:@gradeColor;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:bold;color:white;">
                                    @grade.Value
                                </div>
                                <div>
                                    <div class="badge bg-success">✅ Оцінено</div>
                                    <div class="small text-muted">@grade.CreatedAt.ToShortDateString()</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-warning">⏳ Очікує оцінки</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="card-footer d-flex gap-2">
                @if (!Model.IsGraded && (User.IsInRole("Admin") || User.IsInRole("Student")))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm flex-fill">✏️ Редагувати</a>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                {
                    @if (ViewBag.Grade != null)
                    {
                        <a asp-controller="Grades" asp-action="Edit" asp-route-id="@((ViewBag.Grade as ProjectU.Core.Models.Grade)!.Id)"
                           class="btn btn-outline-warning btn-sm flex-fill">✏️ Змінити оцінку</a>
                        <a asp-controller="Grades" asp-action="Delete" asp-route-id="@((ViewBag.Grade as ProjectU.Core.Models.Grade)!.Id)"
                           class="btn btn-outline-danger btn-sm">🗑️ Видалити оцінку</a>
                    }
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Student"))
                {
                    @if (Model.IsGraded)
                    {
                        <button type="button" class="btn btn-danger btn-sm"
                                onclick="if(confirm('⚠️ Увага! Робота оцінена. Якщо ви її видалите — оцінка також буде видалена. Продовжити?')) window.location='/LabWorks/Delete/@Model.Id'">
                            🗑️ Видалити
                        </button>
                    }
                    else
                    {
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">🗑️ Видалити</a>
                    }
                }
            </div>
            
        </div>
    </div>

    <!-- Результати антиплагіату -->
    <div class="col-md-8 mb-4">
        <div class="card">
            <div class="card-header"><strong>🔍 Результати антиплагіату</strong></div>
            <div class="card-body p-0">
                @if (Model.PlagiarismResults != null && Model.PlagiarismResults.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Порівняно з роботою</th>
                                    <th>Схожість</th>
                                    <th>Дата перевірки</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var result in Model.PlagiarismResults)
                                {
                                    var plagColor = result.SimilarityPercent > 50 ? "#d63031" : result.SimilarityPercent > 20 ? "#fdcb6e" : "#00b894";
                                    <tr>
                                        <td>@(result.ComparedWith?.Title ?? "—")</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="progress flex-fill" style="height: 8px;">
                                                    <div class="progress-bar" style="width: @result.SimilarityPercent%; background: @plagColor;"></div>
                                                </div>
                                                <span class="badge" style="background: @plagColor;">
                                                    @result.SimilarityPercent.ToString("F1")%
                                                </span>
                                            </div>
                                            @if (result.SimilarityPercent > 50)
                                            {
                                                <small class="text-danger">Високий плагіат</small>
                                            }
                                            else if (result.SimilarityPercent > 20)
                                            {
                                                <small class="text-warning">Середній</small>
                                            }
                                            else
                                            {
                                                <small class="text-success">Низький</small>
                                            }
                                        </td>
                                        <td>@result.CheckedAt.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <div style="font-size: 2rem;">🔍</div>
                        <div>Результати перевірки відсутні</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>