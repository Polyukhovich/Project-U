@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = "Здати лабораторну";
}

<h2>Здати лабораторну роботу</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" name="StudentId" value="@ViewData["CurrentUserId"]" />

            <div class="mb-3">
                <label asp-for="AssignmentId" class="form-label">Завдання</label>
                <select asp-for="AssignmentId" asp-items="ViewBag.AssignmentId" class="form-select">
                    <option value="">— Оберіть завдання —</option>
                </select>
                <span asp-validation-for="AssignmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label">Назва роботи</label>
                <input asp-for="Title" class="form-control" placeholder="Наприклад: Лабораторна робота №1" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Файл роботи (.docx або .pdf)</label>
                <input type="file" name="uploadedFile" class="form-control" accept=".docx,.pdf" />
            </div>

            <button type="submit" class="btn btn-primary">📤 Здати</button>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}