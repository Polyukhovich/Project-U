@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var assignmentId = ViewBag.AssignmentId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📤 @Localizer["Title"]</h2>
    @if (assignmentId != null)
    {
        <a asp-controller="Assignments" asp-action="Details" asp-route-id="@assignmentId" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
    }
    else
    {
        <a asp-controller="Assignments" asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
    }
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" name="StudentId" value="@ViewData["CurrentUserId"]" />

                    @if (ViewBag.AssignmentName != null)
                    {
                        <div class="mb-3">
                            <label class="form-label">📋 @Localizer["Assignment"]</label>
                            <input type="text" class="form-control" value="@ViewBag.AssignmentName" disabled />
                            <input type="hidden" asp-for="AssignmentId" />
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label asp-for="AssignmentId" class="form-label">📋 @Localizer["Assignment"]</label>
                            <select asp-for="AssignmentId" asp-items="ViewBag.Assignments" class="form-select">
                                <option value="">@Localizer["SelectAssignment"]</option>
                            </select>
                            <span asp-validation-for="AssignmentId" class="text-danger"></span>
                        </div>
                    }

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@Localizer["WorkTitle"]</label>
                        <input asp-for="Title" class="form-control" placeholder="@Localizer["WorkTitlePlaceholder"]" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📄 @Localizer["File"]</label>
                        <input type="file" name="uploadedFile" class="form-control" accept=".docx,.pdf" />
                        <small class="text-muted">@Localizer["MaxSize"]</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">📤 @Localizer["Submit"]</button>
                        <a asp-controller="Assignments" asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}