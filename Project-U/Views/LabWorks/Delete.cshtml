@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = "Видалити роботу";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ Видалити роботу</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ Ви впевнені що хочете видалити цю роботу? Оцінка також буде видалена!
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-5">Назва</dt>
                    <dd class="col-sm-7"><strong>@Model.Title</strong></dd>

                    <dt class="col-sm-5">Студент</dt>
                    <dd class="col-sm-7">
                        @(Model.Student != null
                                                ? $"{Model.Student.FirstName} {Model.Student.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-5">Курс</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-secondary">@(Model.Course?.Name ?? "—")</span>
                    </dd>

                    <dt class="col-sm-5">Завдання</dt>
                    <dd class="col-sm-7">@(Model.Assignment?.Title ?? "—")</dd>

                    <dt class="col-sm-5">Дата здачі</dt>
                    <dd class="col-sm-7">@Model.UploadedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-5">Статус</dt>
                    <dd class="col-sm-7">
                        @if (Model.IsGraded)
                        {
                            <span class="badge bg-success">✅ Оцінено</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">⏳ Очікує оцінки</span>
                        }
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ Видалити</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>