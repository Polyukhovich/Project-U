@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ @Localizer["Title"]</h2>
    <a asp-controller="Assignments" asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ @Localizer["Warning"]
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-5">@Localizer["WorkTitle"]</dt>
                    <dd class="col-sm-7"><strong>@Model.Title</strong></dd>

                    <dt class="col-sm-5">@Localizer["Student"]</dt>
                    <dd class="col-sm-7">
                        @(Model.Student != null
                                                ? $"{Model.Student.FirstName} {Model.Student.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-5">@Localizer["Course"]</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-secondary">@(Model.Course?.Name ?? "—")</span>
                    </dd>

                    <dt class="col-sm-5">@Localizer["Assignment"]</dt>
                    <dd class="col-sm-7">@(Model.Assignment?.Title ?? "—")</dd>

                    <dt class="col-sm-5">@Localizer["SubmittedAt"]</dt>
                    <dd class="col-sm-7">@Model.UploadedAt.ToString("dd.MM.yyyy HH:mm")</dd>

                    <dt class="col-sm-5">@Localizer["Status"]</dt>
                    <dd class="col-sm-7">
                        @if (Model.IsGraded)
                        {
                            <span class="badge bg-success">✅ @Localizer["Graded"]</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">⏳ @Localizer["Waiting"]</span>
                        }
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ @Localizer["Delete"]</button>
                        <a asp-controller="LabWorks" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary flex-fill">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>