@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>✏️ @Localizer["Title"]</h2>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="StudentId" />
                    <input type="hidden" asp-for="CourseId" />
                    <input type="hidden" asp-for="AssignmentId" />
                    <input type="hidden" asp-for="FilePath" />
                    <input type="hidden" asp-for="UploadedAt" />
                    <input type="hidden" asp-for="IsGraded" />

                    <div class="mb-3">
                        <label class="form-label">👤 @Localizer["Student"]</label>
                        <input type="text" class="form-control"
                               value="@(Model.Student != null ? $"{Model.Student.FirstName} {Model.Student.LastName}" : "—")"
                               disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📚 @Localizer["Course"]</label>
                        <input type="text" class="form-control"
                               value="@(Model.Course?.Name ?? "—")"
                               disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📋 @Localizer["Assignment"]</label>
                        <input type="text" class="form-control"
                               value="@(Model.Assignment?.Title ?? "—")"
                               disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@Localizer["WorkTitle"]</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.FileName))
                    {
                        <div class="mb-3">
                            <label class="form-label">@Localizer["CurrentFile"]</label>
                            <div class="alert alert-info py-2">
                                📄 @Model.FileName
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">@Localizer["NewFile"]</label>
                        <input type="file" name="uploadedFile" class="form-control" accept=".pdf,.docx" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-fill">💾 @Localizer["Save"]</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}