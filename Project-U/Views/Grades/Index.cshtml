@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
    var grouped = ViewBag.GroupedGrades as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 @Localizer["Title"]</h2>
</div>

<!-- Фільтр по курсу -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="form-label mb-0">📚 @Localizer["FilterByCourse"]:</label>
            <select name="courseId" class="form-select" style="max-width: 250px;" onchange="this.form.submit()">
                <option value="">@Localizer["AllCourses"]</option>
                @foreach (var course in ViewBag.Courses as List<ProjectU.Core.Models.Course>)
                {
                    <option value="@course.Id" selected="@(ViewBag.SelectedCourseId != null && ViewBag.SelectedCourseId.ToString() == course.Id.ToString())">
                        @course.Name
                    </option>
                }
            </select>
            @if (ViewBag.SelectedCourseId != null)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✕ @Localizer["Reset"]</a>
            }
        </form>
    </div>
</div>

@if (grouped != null && grouped.Any())
{
    @foreach (var group in grouped)
    {
        var avg = (double)group.Average;
        var avgColor = avg >= 90 ? "#00b894" : avg >= 75 ? "#0984e3" : avg >= 60 ? "#fdcb6e" : "#d63031";

        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center"
                 style="border-left: 4px solid @avgColor;">
                <div>
                    <strong>📚 @group.CourseName</strong>
                    <span class="text-muted small ms-2">@((group.Grades as IEnumerable<dynamic>)?.Count() ?? 0) @Localizer["Grades"]</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="small text-muted">@Localizer["Average"]:</span>
                    <span class="badge" style="background: @avgColor; font-size: 1rem;">
                        @avg.ToString("F1")
                    </span>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (ProjectU.Core.Models.Grade item in group.Grades)
                    {
                        var badgeColor = item.Value >= 90 ? "#00b894" : item.Value >= 75 ? "#0984e3" : item.Value >= 60 ? "#fdcb6e" : "#d63031";
                        var emoji = item.Value >= 90 ? "🏆" : item.Value >= 75 ? "👍" : item.Value >= 60 ? "📝" : "❌";
                        var isAdminOrTeacher = User.IsInRole("Admin") || User.IsInRole("Teacher");
                        var gradeLabel = item.Value >= 90 ? Localizer["Excellent"].Value : item.Value >= 75 ? Localizer["Good"].Value : item.Value >= 60 ? Localizer["Satisfactory"].Value : Localizer["Unsatisfactory"].Value;

                        <div class="col-md-6 col-lg-4 mb-3">
                            @if (isAdminOrTeacher)
                            {
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none d-block">
                                    <div class="card h-100" style="border-top: 3px solid @badgeColor; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease;"
                                         onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.15)'"
                                         onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
                                        <div class="card-body p-3">
                                            <div class="small fw-bold">👤 @(item.Student != null ? $"{item.Student.FirstName} {item.Student.LastName}" : "—")</div>
                                            <div class="small text-muted">🔬 @(item.LabWork?.Title ?? "—")</div>
                                            <div class="small text-muted">📅 @item.CreatedAt.ToShortDateString()</div>
                                            <div class="d-flex justify-content-between align-items-center mt-2">
                                                <small>@emoji @gradeLabel</small>
                                                <div style="width:50px;height:50px;border-radius:50%;background:@badgeColor;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:bold;color:white;">
                                                    @item.Value
                                                </div>
                                            </div>
                                            <div class="progress mt-2" style="height:5px;border-radius:3px;">
                                                <div class="progress-bar" style="width:@item.Value%;background:@badgeColor;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            }
                            else
                            {
                                <div class="card h-100" style="border-top: 3px solid @badgeColor;">
                                    <div class="card-body p-3">
                                        <div class="small text-muted">🔬 @(item.LabWork?.Title ?? "—")</div>
                                        <div class="small text-muted">📅 @item.CreatedAt.ToShortDateString()</div>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <small>@emoji @gradeLabel</small>
                                            <div style="width:50px;height:50px;border-radius:50%;background:@badgeColor;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:bold;color:white;">
                                                @item.Value
                                            </div>
                                        </div>
                                        <div class="progress mt-2" style="height:5px;border-radius:3px;">
                                            <div class="progress-bar" style="width:@item.Value%;background:@badgeColor;"></div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info text-center p-4">
        <div style="font-size: 3rem;">📭</div>
        <div>@Localizer["NoGrades"]</div>
    </div>
}