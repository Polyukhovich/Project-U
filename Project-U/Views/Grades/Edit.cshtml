@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Grade
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>✏️ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="StudentId" />
                    <input type="hidden" asp-for="CourseId" />
                    <input type="hidden" asp-for="LabWorkId" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="mb-3">
                        <label class="form-label">👤 @Localizer["Student"]</label>
                        <input type="text" class="form-control"
                               value="@(Model.Student != null ? $"{Model.Student.FirstName} {Model.Student.LastName}" : "—")"
                               disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📚 @Localizer["Course"]</label>
                        <input type="text" class="form-control"
                               value="@(Model.Course?.Name ?? "—")"
                               disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">🔬 @Localizer["LabWork"]</label>
                        <input type="text" class="form-control"
                               value="@(Model.LabWork?.Title ?? "—")"
                               disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Value" class="form-label">📊 @Localizer["GradeLabel"]</label>
                        <input asp-for="Value" class="form-control" type="number" min="0" max="100" />
                        <span asp-validation-for="Value" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-fill">💾 @Localizer["Save"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}