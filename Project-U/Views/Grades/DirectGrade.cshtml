@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model ProjectU.Core.Models.LabWork
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>➕ @Localizer["Title"]</h2>
    <a asp-action="Index" asp-controller="Assignments" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="DirectGrade" method="post">
                    <input type="hidden" asp-for="StudentId" />
                    <input type="hidden" asp-for="AssignmentId" />
                    <input type="hidden" asp-for="Title" />

                    <div class="mb-3">
                        <label class="form-label">👤 @Localizer["Student"]</label>
                        <input type="text" class="form-control" value="@ViewBag.StudentName" disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📋 @Localizer["Assignment"]</label>
                        <input type="text" class="form-control" value="@ViewBag.AssignmentName" disabled />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📚 @Localizer["Course"]</label>
                        <input type="text" class="form-control" value="@ViewBag.CourseName" disabled />
                    </div>

                    @if (Model.Assignment?.SubTasks != null && Model.Assignment.SubTasks.Any())
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">📋 @Localizer["SubTaskGrades"]</label>
                            @foreach (var subTask in Model.Assignment.SubTasks)
                            {
                                <div class="d-flex align-items-center gap-3 mb-2 p-2 rounded"
                                     style="background: var(--table-stripe);">
                                    <div class="flex-fill">
                                        <div class="fw-bold small">@subTask.Title</div>
                                        <div class="small text-muted">@Localizer["MaxScore"]: @subTask.MaxScore</div>
                                    </div>
                                    <input type="hidden" name="subTaskIds" value="@subTask.Id" />
                                    <input type="number" name="subTaskValues"
                                           class="form-control" style="max-width:100px;"
                                           min="0" max="@subTask.MaxScore"
                                           placeholder="" oninput="updateTotal()" />
                                </div>
                            }
                            <div class="mt-2 fw-bold">
                                @Localizer["Total"]: <span id="totalScore">0</span> / 100
                            </div>
                            <div id="totalWarning" class="alert alert-danger mt-2" style="display:none;">
                                ⚠️ @Localizer["TotalOverLimit"]
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label">📊 @Localizer["GradeLabel"]</label>
                            <input type="number" name="value" class="form-control"
                                   min="0" max="100" style="max-width: 150px;" />
                        </div>
                    }

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success flex-fill">💾 @Localizer["Save"]</button>
                        <a asp-action="Index" asp-controller="Assignments" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateTotal() {
            const inputs = document.querySelectorAll('input[name="subTaskValues"]');
            let total = 0;
            inputs.forEach(i => total += parseInt(i.value) || 0);
            const display = document.getElementById('totalScore');
            const warning = document.getElementById('totalWarning');
            const submitBtn = document.querySelector('button[type="submit"]');
            if (display) {
                display.textContent = total;
                display.style.color = total > 100 ? '#d63031' : '#00b894';
            }
            if (warning) warning.style.display = total > 100 ? 'block' : 'none';
            if (submitBtn) submitBtn.disabled = total > 100;
        }
        updateTotal();
    </script>
}