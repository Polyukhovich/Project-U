@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model ProjectU.Core.Models.Grade
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var isCredit = Model.Course?.CourseType == ProjectU.Core.Models.CourseType.Credit;
    var badgeColor = isCredit
        ? (Model.Value >= 60 ? "#00b894" : "#d63031")
        : (Model.Value >= 90 ? "#00b894" : Model.Value >= 75 ? "#0984e3" : Model.Value >= 60 ? "#fdcb6e" : "#d63031");
    var emoji = isCredit
        ? (Model.Value >= 60 ? "✅" : "❌")
        : (Model.Value >= 90 ? "🏆" : Model.Value >= 75 ? "👍" : Model.Value >= 60 ? "📝" : "❌");
    var label = isCredit
        ? (Model.Value >= 60 ? Localizer["Passed"].Value : Localizer["Failed"].Value)
        : (Model.Value >= 90 ? Localizer["Excellent"].Value : Model.Value >= 75 ? Localizer["Good"].Value : Model.Value >= 60 ? Localizer["Satisfactory"].Value : Localizer["Unsatisfactory"].Value);
    var displayValue = isCredit
        ? (Model.Value >= 60 ? Localizer["Passed"].Value : Localizer["Failed"].Value)
        : Model.Value.ToString();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📊 @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid @badgeColor;">
            <div class="card-body">
                <div class="text-center mb-4">
                    <div style="
                        width: 100px;
                        height: 100px;
                        border-radius: 50%;
                        background: @badgeColor;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 2.5rem;
                        font-weight: bold;
                        color: white;
                        margin: 0 auto 10px;">
                        @displayValue
                    </div>
                    <div style="font-size: 1.5rem;">@emoji @label</div>
                    <div class="progress mt-3" style="height: 8px; border-radius: 4px;">
                        <div class="progress-bar" style="width: @Model.Value%; background: @badgeColor;"></div>
                    </div>
                </div>

                <dl class="row mb-0">
                    <dt class="col-sm-5">@Localizer["Student"]</dt>
                    <dd class="col-sm-7">
                        @(Model.Student != null
                                                ? $"{Model.Student.FirstName} {Model.Student.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-5">@Localizer["Course"]</dt>
                    <dd class="col-sm-7">@(Model.Course?.Name ?? "—")</dd>

                    <dt class="col-sm-5">@Localizer["LabWork"]</dt>
                    <dd class="col-sm-7">@(Model.LabWork?.Title ?? "—")</dd>

                    <dt class="col-sm-5">@Localizer["Date"]</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>

            @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
            {
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm flex-fill">✏️ @Localizer["Edit"]</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger btn-sm">🗑️</a>
                </div>
            }
        </div>
    </div>
</div>