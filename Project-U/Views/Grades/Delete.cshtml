@model ProjectU.Core.Models.Grade
@{
    ViewData["Title"] = "Видалити оцінку";
    var badgeColor = Model.Value >= 90 ? "#00b894" : Model.Value >= 75 ? "#0984e3" : Model.Value >= 60 ? "#fdcb6e" : "#d63031";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ Видалити оцінку</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ Ви впевнені що хочете видалити цю оцінку?
                </div>

                <div class="text-center mb-3">
                    <div style="
                        width: 80px;
                        height: 80px;
                        border-radius: 50%;
                        background: @badgeColor;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        font-size: 2rem;
                        font-weight: bold;
                        color: white;
                        margin: 0 auto;">
                        @Model.Value
                    </div>
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-5">Студент</dt>
                    <dd class="col-sm-7">
                        @(Model.Student != null
                                                ? $"{Model.Student.FirstName} {Model.Student.LastName}"
                                                : "—")
                    </dd>

                    <dt class="col-sm-5">Курс</dt>
                    <dd class="col-sm-7">@(Model.Course?.Name ?? "—")</dd>

                    <dt class="col-sm-5">Лабораторна</dt>
                    <dd class="col-sm-7">@(Model.LabWork?.Title ?? "—")</dd>

                    <dt class="col-sm-5">Дата</dt>
                    <dd class="col-sm-7">@Model.CreatedAt.ToShortDateString()</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ Видалити</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>