@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var code = ViewBag.Code ?? 404;
}

<div class="text-center p-5">
    <div style="font-size: 5rem;">
        @if (code == 404)
        {
            <text>🔍</text>
        }
        else if (code == 403)
        {

            <text>🚫</text>
        }
        else
        {

            <text>⚠️</text>
        }
    </div>

    <h1 style="font-size: 4rem; color: var(--accent);">@code</h1>

    <h3 class="mb-3">
        @if (code == 404)
        {
            <text>@Localizer["NotFound"]</text>
        }
        else if (code == 403)
        {

            <text>@Localizer["Forbidden"]</text>
        }
        else
        {

            <text>@Localizer["SomethingWrong"]</text>
        }
    </h3>

    <p class="text-muted mb-4">
        @if (code == 404)
        {
            <text>@Localizer["NotFoundDesc"]</text>
        }
    </p>

    <div class="d-flex justify-content-center gap-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">🏠 @Localizer["Home"]</a>
        <button onclick="history.back()" class="btn btn-outline-secondary">← @Localizer["Back"]</button>
    </div>
</div>