@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Головна";
}

<!-- Привітання -->
<div class="card mb-4" style="border-top: 4px solid var(--accent);">
    <div class="card-body p-4">
        <h3 class="mb-1">👋 Ласкаво просимо до Project U!</h3>
        <p class="text-muted mb-0">📅 @ViewBag.Today</p>
    </div>
</div>

<!-- Розклад на сьогодні -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>📅 Розклад на сьогодні</strong>
        <a asp-controller="Schedules" asp-action="Index" class="btn btn-sm btn-outline-primary">
            Весь розклад →
        </a>
    </div>
    <div class="card-body p-0">
        @if (ViewBag.TodaySchedules != null && ((List<ProjectU.Core.Models.Schedule>)ViewBag.TodaySchedules).Any())
        {
            <div class="row p-3 g-3">
                @foreach (var schedule in (List<ProjectU.Core.Models.Schedule>)ViewBag.TodaySchedules)
                {
                    <div class="col-md-6">
                        <div class="card h-100" style="border-left: 4px solid var(--accent);">
                            <div class="card-body p-3">
                                <div class="fw-bold">@(schedule.Course?.Name ?? "—")</div>
                                <div class="small text-muted mt-1">
                                    ⏰ @schedule.StartTime.ToString("HH:mm") — @schedule.EndTime.ToString("HH:mm")
                                </div>
                                @if (!string.IsNullOrEmpty(schedule.Room))
                                {
                                    <div class="mt-2">
                                        @if (schedule.Room.StartsWith("http"))
                                        {
                                            <a href="@schedule.Room" target="_blank" class="btn btn-sm btn-outline-info w-100">🔗 Приєднатись онлайн</a>
                                        }
                                        else
                                        {
                                            <span class="small">🏫 @schedule.Room</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="p-5 text-center">
                <div style="font-size: 4rem;">🎉</div>
                <h5 class="mt-2">Сьогодні занять немає!</h5>
                <p class="text-muted">Можна відпочити 😊</p>
            </div>
        }
    </div>
</div>