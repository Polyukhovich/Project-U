@model ProjectU.Core.Models.ApplicationUser
@{
    ViewData["Title"] = "Видалити користувача";
    var currentRole = ViewBag.CurrentRole as string ?? "—";
    var roleBadge = currentRole == "Admin" ? "bg-danger" :
                    currentRole == "Teacher" ? "bg-success" :
                    currentRole == "Student" ? "bg-primary" : "bg-secondary";
    var roleEmoji = currentRole == "Admin" ? "⚙️" :
                    currentRole == "Teacher" ? "👨‍🏫" :
                    currentRole == "Student" ? "👨‍🎓" : "👤";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ Видалити користувача</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ Ви впевнені що хочете видалити цього користувача? Цю дію неможливо скасувати!
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-4">Ім'я</dt>
                    <dd class="col-sm-8"><strong>@Model.FirstName @Model.LastName</strong></dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8"><small>@Model.Email</small></dd>

                    <dt class="col-sm-4">Роль</dt>
                    <dd class="col-sm-8">
                        <span class="badge @roleBadge">@roleEmoji @currentRole</span>
                    </dd>

                    <dt class="col-sm-4">Група</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(Model.Group?.Name))
                        {
                            <span class="badge bg-secondary">@Model.Group.Name</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>
                </dl>

                <form asp-action="DeleteUser" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ Видалити</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>