@model Project_U.Models.CreateUserViewModel
@{
    ViewData["Title"] = "Створити користувача";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>➕ Створити користувача</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="CreateUser" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label">Ім'я</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Іван" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label">Прізвище</label>
                        <input asp-for="LastName" class="form-control" placeholder="Іваненко" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="ivan@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">Роль</label>
                        <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">— Оберіть роль —</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label">Група</label>
                        <select asp-for="GroupId" asp-items="ViewBag.GroupId" class="form-select">
                            <option value="">— Без групи (для викладача/адміна) —</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">➕ Створити</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}