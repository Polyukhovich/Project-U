@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model Project_U.Models.CreateUserViewModel
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>➕ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="CreateUser" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label">@Localizer["FirstName"]</label>
                        <input asp-for="FirstName" class="form-control" placeholder="@Localizer["FirstNamePlaceholder"]" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label">@Localizer["LastName"]</label>
                        <input asp-for="LastName" class="form-control" placeholder="@Localizer["LastNamePlaceholder"]" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">@Localizer["Email"]</label>
                        <input asp-for="Email" class="form-control" placeholder="@Localizer["EmailPlaceholder"]" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">@Localizer["Password"]</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">@Localizer["Role"]</label>
                        <select asp-for="Role" asp-items="ViewBag.Roles" class="form-select">
                            <option value="">@Localizer["SelectRole"]</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label">@Localizer["Group"]</label>
                        <select asp-for="GroupId" asp-items="ViewBag.GroupId" class="form-select">
                            <option value="">@Localizer["NoGroup"]</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">➕ @Localizer["Create"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}