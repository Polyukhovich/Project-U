@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@using Microsoft.AspNetCore.Identity
@using ProjectU.Core.Models
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project U</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <!-- PWA -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#6c5ce7" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
</head>
<body>
    <script>
        // Застосовуємо тему одразу щоб уникнути мерехтіння
        const t = localStorage.getItem('theme');
        if (t && t !== 'default') document.body.classList.add('theme-' + t);
    </script>
    <!-- Overlay для мобільних -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    <!-- Офлайн банер -->
    <div id="offlineBanner" style="display:none; position:fixed; top:0; left:0; right:0; background:#d63031; color:white; text-align:center; padding:8px; z-index:99999; font-size:0.9rem;">
        📡 @Localizer["OfflineBanner"]
    </div>
    <!-- Боковий бар -->
    <div class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
            🎓 Project U
        </a>

        @if (User.Identity!.IsAuthenticated)
        {
            <li class="nav-item">
                @{
                    var currentUser = await UserManager.GetUserAsync(User);
                }

                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                    👤
                    <div style="display:inline-block; line-height:1.2;">
                        <div style="font-size:0.95rem; color:white; font-weight:500;">
                            @(currentUser?.FirstName ?? "") @(currentUser?.LastName ?? "")
                        </div>
                        <div style="font-size:0.75rem; color:rgba(255,255,255,0.5);">
                            @User.Identity!.Name
                        </div>
                    </div>
                </a>
            </li>
            <div class="sidebar-section">@Localizer["Navigation"]</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 @Localizer["Home"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Groups" asp-action="Index">👥 @Localizer["Groups"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Courses" asp-action="Index">📚 @Localizer["Courses"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Schedules" asp-action="Index">📅 @Localizer["Schedules"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Grades" asp-action="Index">📊 @Localizer["Grades"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Assignments" asp-action="Index">📋 @Localizer["Assignments"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Settings" asp-action="Index">⚙️ @Localizer["Settings"]</a>
                </li>
            </ul>

            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-section">@Localizer["Administration"]</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Index">⚙️ @Localizer["Admin"]</a>
                    </li>
                </ul>
            }
        }
        else
        {
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">🔑 @Localizer["Login"]</a>
                </li>
            </ul>
        }
    </div>

    <!-- Основний контент -->
    <div class="main-content" id="mainContent">
        <div class="topbar">
            <button class="toggle-btn" onclick="toggleSidebar()">☰</button>
            <span class="text-muted">@ViewData["Title"]</span>

            @if (User.Identity!.IsAuthenticated)
            {
                <div class="notification-wrapper" style="position: relative;">
                    <button onclick="toggleNotifications()" class="btn btn-sm btn-outline-secondary position-relative">
                        🔔
                        <span id="unreadBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none; font-size:0.6rem;">0</span>
                    </button>

                    <!-- Випадаюче вікно сповіщень -->
                    <div id="notificationDropdown" style="
                        display: none;
                        position: absolute;
                        right: 0;
                        top: 45px;
                        width: 320px;
                        border-radius: 12px;
                        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
                        z-index: 9999;
                        overflow: hidden;
                    " class="notification-dropdown">
                        <div class="notification-dropdown-header">
                            <strong>🔔 Сповіщення</strong>
                            <span id="markAllBtn" style="display:none">
                                <button onclick="markAllRead()" class="btn btn-sm btn-outline-success">✅ Прочитано</button>
                            </span>
                        </div>
                        <div id="notificationList" style="max-height: 350px; overflow-y: auto; padding: 5px 0;">
                            <p class="text-center text-muted p-3">Завантаження...</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="content-area">
            @RenderBody()
        </div>

        <div class="footer">
            &copy; 2026 - Project U
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <script src="~/lib/signalr/dist/browser/signalr.js"></script>

    @if (User.Identity!.IsAuthenticated)
    {
        <script src="~/js/notifications.js" asp-append-version="true"></script>
        <script>
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notifications")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveNotification", function (message) {
                const url = getNotificationUrl(message);
                showToast(message, url);
                loadNotifications();
                sendBrowserNotification(message);
            });

            connection.start().catch(err => console.error(err));
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function() {
                navigator.serviceWorker.register('/sw.js')
                    .then(reg => console.log('SW зареєстровано:', reg.scope))
                    .catch(err => console.error('SW помилка:', err));
            });
        }
    </script>
</body>
</html>