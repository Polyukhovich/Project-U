@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project U</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Project_U.styles.css" asp-append-version="true" />
</head>
<body>
    <!-- Боковий бар -->
    <div class="sidebar" id="sidebar">
        <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
            🎓 Project U
        </a>

        @if (User.Identity!.IsAuthenticated)
        {
            <div class="sidebar-section">@Localizer["Navigation"]</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">🏠 @Localizer["Home"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Groups" asp-action="Index">👥 @Localizer["Groups"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Courses" asp-action="Index">📚 @Localizer["Courses"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Schedules" asp-action="Index">📅 @Localizer["Schedules"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Grades" asp-action="Index">📊 @Localizer["Grades"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Assignments" asp-action="Index">📋 @Localizer["Assignments"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="LabWorks" asp-action="Index">🔬 @Localizer["LabWorks"]</a>
                </li>
            </ul>

            @if (User.IsInRole("Admin"))
            {
                <div class="sidebar-section">@Localizer["Administration"]</div>
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Index">⚙️ @Localizer["Admin"]</a>
                    </li>
                </ul>
            }

            <div class="sidebar-section">@Localizer["Account"]</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Index">👤 @User.Identity.Name</a>
                </li>
                <li class="nav-item">
                    <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                        <button type="submit" class="nav-link btn btn-link text-start w-100">🚪 @Localizer["Logout"]</button>
                    </form>
                </li>
            </ul>
        }
        else
        {
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">🔑 @Localizer["Login"]</a>
                </li>
            </ul>
        }

        <div class="sidebar-section">@Localizer["Language"]</div>
        <ul class="nav flex-column mb-3">
            <li class="nav-item">
                <form asp-controller="SelectLanguage" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="cultureName" value="uk-UA" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="nav-link btn btn-link text-start w-100">🇺🇦 Українська</button>
                </form>
            </li>
            <li class="nav-item">
                <form asp-controller="SelectLanguage" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="cultureName" value="en-US" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="nav-link btn btn-link text-start w-100">🇺🇸 English</button>
                </form>
            </li>
        </ul>
    </div>

    <!-- Основний контент -->
    <div class="main-content" id="mainContent">
        <div class="topbar">
            <button class="toggle-btn" onclick="toggleSidebar()">☰</button>
            <span class="text-muted">@ViewData["Title"]</span>

            @if (User.Identity!.IsAuthenticated)
            {
                <div class="notification-wrapper" style="position: relative;">
                    <button onclick="toggleNotifications()" class="btn btn-sm btn-outline-secondary position-relative">
                        🔔
                        <span id="unreadBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none; font-size:0.6rem;">0</span>
                    </button>

                    <!-- Випадаюче вікно сповіщень -->
                    <div id="notificationDropdown" style="
                    display: none;
                    position: absolute;
                    right: 0;
                    top: 45px;
                    width: 320px;
                    background: white;
                    border-radius: 12px;
                    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
                    z-index: 9999;
                    overflow: hidden;
                ">
                        <div style="padding: 12px 15px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
                            <strong>🔔 Сповіщення</strong>
                            <span id="markAllBtn" style="display:none">
                                <button onclick="markAllRead()" class="btn btn-sm btn-outline-success">✅ Прочитано</button>
                            </span>
                        </div>
                        <div id="notificationList" style="max-height: 350px; overflow-y: auto; padding: 5px 0;">
                            <p class="text-center text-muted p-3">Завантаження...</p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="content-area">
            @RenderBody()
        </div>

        <div class="footer">
            &copy; 2026 - Project U
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
            function toggleSidebar() {
                const sidebar = document.getElementById('sidebar');
                const mainContent = document.getElementById('mainContent');

                if (window.innerWidth <= 768) {
                    sidebar.classList.toggle('mobile-open');
                } else {
                    sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('expanded');
                }
            }

            document.addEventListener('click', function(e) {
                const sidebar = document.getElementById('sidebar');
                const toggleBtn = document.querySelector('.toggle-btn');

                if (window.innerWidth <= 768 &&
                    !sidebar.contains(e.target) &&
                    !toggleBtn.contains(e.target)) {
                    sidebar.classList.remove('mobile-open');
                }
            });

            document.querySelectorAll('.sidebar .nav-link').forEach(link => {
                if (link.href === window.location.href) {
                    link.classList.add('active');
                }
            });
    </script>
    <!-- SignalR клієнт -->
    <script src="~/lib/signalr/dist/browser/signalr.js"></script>

    @if (User.Identity!.IsAuthenticated)
    {
        <script>
            // ===== SignalR =====
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notifications")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveNotification", function (message) {
                showToast(message);
                loadNotifications();
                sendBrowserNotification(message);
            });

            connection.start().catch(err => console.error(err));

            // ===== Toggle dropdown =====
            function toggleNotifications() {
                const dropdown = document.getElementById('notificationDropdown');
                dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
                if (dropdown.style.display === 'block') loadNotifications();
            }

            // Закриваємо при кліку поза вікном
            document.addEventListener('click', function(e) {
                const wrapper = document.querySelector('.notification-wrapper');
                if (wrapper && !wrapper.contains(e.target)) {
                    document.getElementById('notificationDropdown').style.display = 'none';
                }
            });
           
                        function getNotificationUrl(message) {
                if (message.includes('оцінку')) return '/Grades';
                if (message.includes('здав роботу') || message.includes('роботу')) return '/Assignments';
                if (message.includes('розклад')) return '/Schedules';
                if (message.includes('дедлайн') || message.includes('Дедлайн')) return '/Assignments';
                if (message.includes('схожість') || message.includes('перевірку')) return '/LabWorks';
                return '/';
            }
            // ===== Генерація HTML сповіщення =====
            function buildNotificationHtml(n) {
                var bg = n.isRead ? 'white' : '#f0eeff';
                var badge = n.isRead ? '' : '<span style="float:right; background:#6c5ce7; color:white; border-radius:10px; padding:1px 8px; font-size:0.7rem;">Нове</span>';
                var url = getNotificationUrl(n.message);
                return '<div style="padding:12px 15px; border-bottom:1px solid #f0f0f0; background:' + bg + '; cursor:pointer;" onclick="readAndGo(' + n.id + ', \'' + url + '\')">'
                    + '<div style="font-size:0.85rem; color:#333;">' + n.message + '</div>'
                    + '<div style="font-size:0.75rem; color:#999; margin-top:3px;">🕐 ' + n.createdAt + '</div>'
                    + badge
                    + '</div>';
            }
            
            // ===== Завантаження сповіщень =====
            function loadNotifications() {
                fetch('/Notifications/GetNotifications')
                    .then(r => r.json())
                    .then(data => {
                        const list = document.getElementById('notificationList');
                        const badge = document.getElementById('unreadBadge');
                        const markAllBtn = document.getElementById('markAllBtn');

                        // Спочатку фільтруємо
                        const unread = data.filter(n => !n.isRead);

                        badge.style.display = unread.length > 0 ? 'inline' : 'none';
                        badge.textContent = unread.length;

                        // Потім показуємо/ховаємо кнопку
                        if (markAllBtn) {
                            markAllBtn.style.display = unread.length > 0 ? 'inline' : 'none';
                        }

                        if (unread.length === 0) {
                            list.innerHTML = '<p class="text-center text-muted p-3">Немає нових сповіщень</p>';
                            return;
                        }

                        list.innerHTML = unread.map(n => buildNotificationHtml(n)).join('');
                    });
            }

            // ===== Прочитано =====
            function markAllRead() {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                fetch('/Notifications/MarkAllRead', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token || '' }
                }).then(() => {
                    loadNotifications();
                    document.getElementById('notificationDropdown').style.display = 'none';
                });
            }
            // Позначити як прочитане і перейти
            function readAndGo(id, url) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                fetch(`/Notifications/MarkRead/${id}`, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token || '' }
                }).then(() => {
                    loadNotifications();
                    window.location = url;
                });
            }
            // ===== Toast =====
            function showToast(message) {
                const toast = document.createElement('div');
                toast.className = 'toast-notification';
                toast.innerHTML = `🔔 ${message}`;
                document.body.appendChild(toast);
                setTimeout(() => toast.classList.add('show'), 100);
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 300);
                }, 4000);
            }

            // ===== Browser Notifications =====
            function sendBrowserNotification(message) {
                if ('Notification' in window && Notification.permission === 'granted') {
                    new Notification('Project U 🎓', {
                        body: message,
                        icon: '/favicon.ico'
                    });
                }
            }

            // Запит дозволу
            if ('Notification' in window && Notification.permission === 'default') {
                Notification.requestPermission();
            }

            // Завантажуємо при старті
            loadNotifications();
            setInterval(loadNotifications, 30000);
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>