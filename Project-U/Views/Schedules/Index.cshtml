@model X.PagedList.IPagedList<ProjectU.Core.Models.Schedule>
@using X.PagedList.Mvc.Core
@using X.PagedList
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<h2>@Localizer["Title"]</h2>

<p>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Create" class="btn btn-primary">➕ @Localizer["AddSchedule"]</a>
    }
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>@Localizer["DayOfWeek"]</th>
            <th>@Localizer["StartTime"]</th>
            <th>@Localizer["EndTime"]</th>
            <th>@Localizer["Room"]</th>
            <th>@Localizer["Course"]</th>
            <th>@Localizer["Group"]</th>
            <th>@Localizer["Actions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DayOfWeek</td>
                <td>@item.StartTime</td>
                <td>@item.EndTime</td>
                <td>@item.Room</td>
                <td>@(item.Course?.Name ?? "—")</td>
                <td>@(item.Group?.Name ?? "—")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">@Localizer["Details"]</a>
                    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">@Localizer["Edit"]</a>
                    }
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">@Localizer["Delete"]</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-center mt-3">
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }),
        new PagedListRenderOptions
        {
            LiElementClasses = new[] { "page-item" },
            PageClasses = new[] { "page-link" }
        })
</div