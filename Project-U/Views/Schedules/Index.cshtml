@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
    var grouped = ViewBag.GroupedSchedules as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📅 @Localizer["Title"]</h2>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
        {
            <a asp-action="Create" class="btn btn-primary">➕ @Localizer["AddLesson"]</a>
        }
        else if (User.IsInRole("Student"))
        {
            @if (ViewBag.IsAll == true)
            {
                <a asp-action="Index" class="btn btn-outline-secondary">📅 @Localizer["MySchedule"]</a>
            }
            else
            {
                <a asp-action="Index" asp-route-all="true" class="btn btn-outline-secondary">🌍 @Localizer["AllSchedules"]</a>
            }
        }
    </div>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
{
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="d-flex gap-2 align-items-center">
                <label class="form-label mb-0">👥 @Localizer["FilterByGroup"]:</label>
                <select name="groupId" class="form-select" style="max-width: 200px;" onchange="this.form.submit()">
                    <option value="">@Localizer["AllGroups"]</option>
                    @foreach (var group in ViewBag.Groups as List<ProjectU.Core.Models.Group>)
                    {
                        <option value="@group.Id" selected="@(ViewBag.SelectedGroupId != null && ViewBag.SelectedGroupId.ToString() == group.Id.ToString())">
                            @group.Name
                        </option>
                    }
                </select>
                @if (ViewBag.SelectedGroupId != null)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✕</a>
                }
            </form>
        </div>
    </div>
}

@if (grouped != null)
{
    <div class="row">
        @foreach (var group in grouped)
        {
            var schedules = group.Schedules as List<ProjectU.Core.Models.Schedule>;
            var hasSchedules = schedules != null && schedules.Any();

            <div class="col-md-6 mb-6">
                <div class="card h-100" style="border-top: 4px solid var(--accent);">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <span style="font-size:1.2rem;">
                                @switch ((string)group.Day)
                                {
                                    case "Понеділок":
                                        <text>📘</text>
                                        break;
                                    case "Вівторок":

                                        <text>📗</text>
                                        break;
                                    case "Середа":

                                        <text>📙</text>
                                        break;
                                    case "Четвер":

                                        <text>📕</text>
                                        break;
                                    case "П'ятниця":

                                        <text>📓</text>
                                        break;
                                    case "Субота":

                                        <text>📔</text>
                                        break;
                                }
                            </span>
                            <a asp-action="ByDay" asp-route-day="@group.Day" class="text-decoration-none">
                                <strong>@group.Day</strong>
                            </a>
                        </div>
                        @if (hasSchedules)
                        {
                            <span class="badge bg-primary">@schedules!.Count</span>
                        }
                    </div>
                    <div class="card-body p-2">
                        @if (hasSchedules)
                        {
                            @foreach (var schedule in schedules!)
                            {
                                var nextDate = schedule.Dates?
                                .Where(d => d.Date >= DateOnly.FromDateTime(DateTime.Today) &&
                                d.Date.DayOfWeek == (DayOfWeek)Array.IndexOf(
                                new[] { "Понеділок", "Вівторок", "Середа", "Четвер", "П'ятниця", "Субота" },
                                (string)group.Day))
                                .OrderBy(d => d.Date)
                                .FirstOrDefault();

                                <div class="p-2 mb-2 rounded" style="background: var(--table-stripe); border-left: 3px solid var(--accent);">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <div class="fw-bold">@(schedule.Course?.Name ?? "—")</div>
                                            @if (!User.IsInRole("Student"))
                                            {
                                                <div class="fw-bold text-muted small mt-1">👥 @(schedule.Group?.Name ?? "—")</div>
                                            }
                                            @{
                                                var lessonBadge = schedule.LessonType switch
                                                {
                                                    "Lab" => ("bg-success", "🔬"),
                                                    "Practice" => ("bg-warning", "📝"),
                                                    _ => ("bg-info", "📖")
                                                };
                                            }
                                            <span class="badge @lessonBadge.Item1">@lessonBadge.Item2 @Localizer[schedule.LessonType ?? "Lecture"]</span>
                                            <div class="small text-muted">
                                                ⏰ @schedule.StartTime.ToString("HH:mm") — @schedule.EndTime.ToString("HH:mm")
                                            </div>
                                            @if (schedule.Course?.Teacher != null)
                                            {
                                                <div class="small text-muted">
                                                    👨‍🏫 @schedule.Course.Teacher.FirstName @schedule.Course.Teacher.LastName
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(schedule.Room))
                                            {
                                                @if (schedule.Room.StartsWith("http"))
                                                {
                                                    <a href="@schedule.Room" target="_blank" class="btn btn-sm btn-outline-info mt-1 w-100">🔗 @Localizer["Online"]</a>
                                                }
                                                else
                                                {
                                                    <div class="small">🏫 @schedule.Room</div>
                                                }
                                            }
                                            @if (nextDate != null)
                                            {
                                                <div class="small">
                                                    <span class="badge bg-primary mt-1">@nextDate.Date.ToString("dd.MM.yyyy")</span>
                                                </div>
                                            }
                                        </div>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                                        {
                                            <div class="d-flex flex-column gap-1">
                                                <a asp-action="Edit" asp-route-id="@schedule.Id" class="btn btn-sm btn-warning p-1">✏️</a>
                                                <a asp-action="Delete" asp-route-id="@schedule.Id" class="btn btn-sm btn-danger p-1">🗑️</a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted p-3">
                                <div style="font-size:2rem;">😴</div>
                                <div class="small">@Localizer["NoLessons"]</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">📭 @Localizer["NoSchedule"]</div>
}