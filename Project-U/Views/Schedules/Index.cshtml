@model X.PagedList.IPagedList<ProjectU.Core.Models.Schedule>
@using X.PagedList.Mvc.Core
@using X.PagedList
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<h2>@Localizer["Title"]</h2>

<p>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Create" class="btn btn-primary">➕ @Localizer["AddSchedule"]</a>
    }
</p>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Localizer["StartTime"]</th>
                <th>@Localizer["EndTime"]</th>
                <th>@Localizer["Room"]</th>
                <th>@Localizer["Course"]</th>
                <th>@Localizer["Group"]</th>
                <th>Дат занять</th>
                <th>@Localizer["Actions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.StartTime.ToString("HH:mm")</td>
                    <td>@item.EndTime.ToString("HH:mm")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Room))
                        {
                            @if (item.Room.StartsWith("http"))
                            {
                                <a href="@item.Room" target="_blank" class="btn btn-sm btn-outline-info">🔗 Онлайн</a>
                            }
                            else
                            {
                                <span>🏫 @item.Room</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>@(item.Course?.Name ?? "—")</td>
                    <td><span class="badge bg-secondary">@(item.Group?.Name ?? "—")</span></td>
                    <td><span class="badge bg-primary">@(item.Dates?.Count ?? 0)</span></td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">@Localizer["Details"]</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">✏️</a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">🗑️</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-center mt-3">
    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }),
    new PagedListRenderOptions
    {
        LiElementClasses = new[] { "page-item" },
        PageClasses = new[] { "page-link" }
    })
</div>