@model ProjectU.Core.Models.Schedule
@{
    ViewData["Title"] = "Видалити розклад";
}

<h2>Видалити розклад</h2>

<div class="alert alert-warning">
    ⚠️ Ви впевнені що хочете видалити цей розклад?
</div>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Курс</dt>
            <dd class="col-sm-9">@(Model?.Course?.Name ?? "—")</dd>

            <dt class="col-sm-3">Група</dt>
            <dd class="col-sm-9">@(Model?.Group?.Name ?? "—")</dd>

            <dt class="col-sm-3">Час</dt>
            <dd class="col-sm-9">@Model?.StartTime.ToString("HH:mm") — @Model?.EndTime.ToString("HH:mm")</dd>

            <dt class="col-sm-3">Аудиторія</dt>
            <dd class="col-sm-9">@(string.IsNullOrEmpty(Model?.Room) ? "—" : Model.Room)</dd>

            <dt class="col-sm-3">Кількість занять</dt>
            <dd class="col-sm-9">@(Model?.Dates?.Count ?? 0)</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">🗑️ Видалити</button>
    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
</form>