@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Schedule
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ @Localizer["Warning"]
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-5">@Localizer["Course"]</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-secondary">@(Model?.Course?.Name ?? "—")</span>
                    </dd>

                    <dt class="col-sm-5">@Localizer["Group"]</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-secondary">@(Model?.Group?.Name ?? "—")</span>
                    </dd>

                    <dt class="col-sm-5">@Localizer["Time"]</dt>
                    <dd class="col-sm-7">
                        ⏰ @Model?.StartTime.ToString("HH:mm") — @Model?.EndTime.ToString("HH:mm")
                    </dd>

                    <dt class="col-sm-5">@Localizer["Room"]</dt>
                    <dd class="col-sm-7">
                        @if (!string.IsNullOrEmpty(Model?.Room))
                        {
                            @if (Model.Room.StartsWith("http"))
                            {
                                <a href="@Model.Room" target="_blank" class="btn btn-sm btn-outline-info">🔗 @Localizer["Online"]</a>
                            }
                            else
                            {
                                <span>🏫 @Model.Room</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-5">@Localizer["DatesCount"]</dt>
                    <dd class="col-sm-7">
                        <span class="badge bg-primary">@(Model?.Dates?.Count ?? 0)</span>
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ @Localizer["Delete"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>