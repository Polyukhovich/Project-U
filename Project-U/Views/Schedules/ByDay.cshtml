@{
    ViewData["Title"] = $"Розклад — {ViewBag.Day}";
    var schedules = ViewBag.Schedules as List<ProjectU.Core.Models.Schedule>;
    var today = DateOnly.FromDateTime(DateTime.Today);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📅 @ViewBag.Day</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

@if (schedules != null && schedules.Any())
{
    <div class="row">
        @foreach (var schedule in schedules)
        {
            var nextDate = schedule.Dates?
            .Where(d => d.Date >= today)
            .OrderBy(d => d.Date)
            .FirstOrDefault();

            <div class="col-md-6 mb-4">
                <div class="card" style="border-top: 4px solid var(--accent);">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong>📚 @(schedule.Course?.Name ?? "—")</strong>
                        <span class="badge bg-secondary">@(schedule.Group?.Name ?? "—")</span>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-5">⏰ Час</dt>
                            <dd class="col-sm-7">
                                @schedule.StartTime.ToString("HH:mm") — @schedule.EndTime.ToString("HH:mm")
                            </dd>

                            <dt class="col-sm-5">🏫 Аудиторія</dt>
                            <dd class="col-sm-7">
                                @if (!string.IsNullOrEmpty(schedule.Room))
                                {
                                    @if (schedule.Room.StartsWith("http"))
                                    {
                                        <a href="@schedule.Room" target="_blank" class="btn btn-sm btn-outline-info">🔗 Онлайн</a>
                                    }
                                    else
                                    {
                                        <span>🏫 @schedule.Room</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </dd>

                            <dt class="col-sm-5">📅 Наступне</dt>
                            <dd class="col-sm-7">
                                @if (nextDate != null)
                                {
                                    <span class="badge bg-primary">@nextDate.Date.ToString("dd.MM.yyyy")</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Немає дат</span>
                                }
                            </dd>
                        </dl>

                        <!-- Всі майбутні дати -->
                        @{
                            var futureDates = schedule.Dates?
                            .Where(d => d.Date >= today)
                            .OrderBy(d => d.Date)
                            .ToList();
                        }
                        @if (futureDates != null && futureDates.Any())
                        {
                            <div class="mt-3">
                                <small class="text-muted">Всі дати:</small>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    @foreach (var date in futureDates)
                                    {
                                        <span class="badge bg-primary">@date.Date.ToString("dd.MM")</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
                    {
                        <div class="card-footer d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@schedule.Id" class="btn btn-warning btn-sm flex-fill">✏️ Редагувати</a>
                            <a asp-action="Delete" asp-route-id="@schedule.Id" class="btn btn-danger btn-sm">🗑️</a>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center p-4">
        <div style="font-size: 3rem;">😴</div>
        <div>Занять у @ViewBag.Day немає</div>
    </div>
}