@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Schedule
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>✏️ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Edit" method="post" id="scheduleForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label class="form-label">⏰ @Localizer["Pair"]</label>
                        <select id="pairTemplate" class="form-select" onchange="setPairTime(this.value)">
                            <option value="">@Localizer["SelectPair"]</option>
                            <option value="08:00,09:20">1 @Localizer["Pair"] (08:00 — 09:20)</option>
                            <option value="09:30,10:50">2 @Localizer["Pair"] (09:30 — 10:50)</option>
                            <option value="11:00,12:20">3 @Localizer["Pair"] (11:00 — 12:20)</option>
                            <option value="12:30,13:50">4 @Localizer["Pair"] (12:30 — 13:50)</option>
                            <option value="14:00,15:20">5 @Localizer["Pair"] (14:00 — 15:20)</option>
                            <option value="15:30,16:50">6 @Localizer["Pair"] (15:30 — 16:50)</option>
                            <option value="17:00,18:20">7 @Localizer["Pair"] (17:00 — 18:20)</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartTime" class="form-label">@Localizer["StartTime"]</label>
                            <input asp-for="StartTime" class="form-control" type="time" id="startTime" />
                            <span asp-validation-for="StartTime" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndTime" class="form-label">@Localizer["EndTime"]</label>
                            <input asp-for="EndTime" class="form-control" type="time" id="endTime" />
                            <span asp-validation-for="EndTime" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Room" class="form-label">@Localizer["Room"]</label>
                        <input asp-for="Room" class="form-control" placeholder="@Localizer["RoomPlaceholder"]" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="LessonType" class="form-label">📖 @Localizer["LessonType"]</label>
                        <select asp-for="LessonType" class="form-select">
                            <option value="Lecture">📖 @Localizer["Lecture"]</option>
                            <option value="Lab">🔬 @Localizer["Lab"]</option>
                            <option value="Practice">📝 @Localizer["Practice"]</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="GroupId" class="form-label">@Localizer["Group"]</label>
                        <select asp-for="GroupId" asp-items="@(ViewData["GroupId"] as SelectList)"
                                class="form-select" id="groupSelect" onchange="loadCourses(this.value)">
                            <option value="">@Localizer["SelectGroup"]</option>
                        </select>
                        <span asp-validation-for="GroupId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label">@Localizer["Course"]</label>
                        <select asp-for="CourseId" class="form-select" id="courseSelect" disabled>
                            <option value="">@Localizer["SelectGroupFirst"]</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📅 @Localizer["Dates"]</label>
                        <div class="card mb-3 p-3" style="background: var(--input-bg);">
                            <div class="fw-bold mb-2 small">⚡ @Localizer["QuickSelect"]</div>
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label small">@Localizer["From"]</label>
                                    <input type="date" id="rangeStart" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">@Localizer["To"]</label>
                                    <input type="date" id="rangeEnd" class="form-control form-control-sm" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label small">@Localizer["DayOfWeek"]</label>
                                    <select id="rangeDayOfWeek" class="form-select form-select-sm">
                                        <option value="1">@Localizer["Monday"]</option>
                                        <option value="2">@Localizer["Tuesday"]</option>
                                        <option value="3">@Localizer["Wednesday"]</option>
                                        <option value="4">@Localizer["Thursday"]</option>
                                        <option value="5">@Localizer["Friday"]</option>
                                        <option value="6">@Localizer["Saturday"]</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mt-2 d-flex gap-2">
                                <button type="button" onclick="addDateRange()" id="addRangeBtn" class="btn btn-sm btn-outline-primary" disabled>
                                    ➕ @Localizer["AddRange"]
                                </button>
                                <button type="button" onclick="clearDates()" class="btn btn-sm btn-outline-danger">
                                    🗑️ @Localizer["ClearAll"]
                                </button>
                            </div>
                        </div>

                        <div id="calendar" class="border rounded p-2 mb-2"></div>
                        <div id="selectedDates" class="d-flex flex-wrap gap-1 mb-2">
                            @foreach (var date in Model.Dates.OrderBy(d => d.Date))
                            {
                                <span class="badge bg-primary">@date.Date.ToString("dd.MM.yyyy")</span>
                            }
                        </div>
                        <input type="hidden" name="selectedDatesJson" id="selectedDatesJson"
                               value="@string.Join(",", Model.Dates.Select(d => d.Date.ToString("yyyy-MM-dd")))" />
                        <small class="text-muted">@Localizer["ClickToSelect"]</small>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-fill">💾 @Localizer["Save"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/uk.js"></script>

    <script>
        function setPairTime(value) {
            if (!value) return;
            const [start, end] = value.split(',');
            document.getElementById('startTime').value = start;
            document.getElementById('endTime').value = end;
        }

        const existingDates = "@string.Join(",", Model.Dates.Select(d => d.Date.ToString("yyyy-MM-dd")))".split(',').filter(d => d);

        const fp = flatpickr("#calendar", {
            inline: true,
            mode: "multiple",
            locale: "uk",
            dateFormat: "Y-m-d",
            defaultDate: existingDates,
            onChange: function(dates) {
                const container = document.getElementById('selectedDates');
                container.innerHTML = dates.map(d => {
                    const formatted = d.toLocaleDateString('uk-UA');
                    return '<span class="badge bg-primary">' + formatted + '</span>';
                }).join('');
                document.getElementById('selectedDatesJson').value =
                            dates.map(d => {
            const year = d.getFullYear();
            const month = String(d.getMonth() + 1).padStart(2, '0');
            const day = String(d.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }).join(',');
            }
        });

        document.getElementById('rangeStart').addEventListener('change', checkRangeFields);
        document.getElementById('rangeEnd').addEventListener('change', checkRangeFields);

        function checkRangeFields() {
            const start = document.getElementById('rangeStart').value;
            const end = document.getElementById('rangeEnd').value;
            document.getElementById('addRangeBtn').disabled = !start || !end;
        }

        function addDateRange() {
            const startVal = document.getElementById('rangeStart').value;
            const endVal = document.getElementById('rangeEnd').value;
            if (!startVal || !endVal) return;
            const start = new Date(startVal);
            const end = new Date(endVal);
            const dayOfWeek = parseInt(document.getElementById('rangeDayOfWeek').value);
            if (start > end) { alert('@Localizer["From"] > @Localizer["To"]'); return; }
            const datesToAdd = [];
            const current = new Date(start);
            while (current.getDay() !== dayOfWeek % 7) { current.setDate(current.getDate() + 1); }
            while (current <= end) { datesToAdd.push(new Date(current)); current.setDate(current.getDate() + 7); }
            fp.setDate([...fp.selectedDates, ...datesToAdd], true);
        }

        function clearDates() {
            if (fp.selectedDates.length === 0) return;
            if (confirm('@Localizer["ClearAll"]?')) {
                fp.clear();
                document.getElementById('selectedDatesJson').value = '';
                document.getElementById('selectedDates').innerHTML = '';
            }
        }
                async function loadCourses(groupId) {
            const courseSelect = document.getElementById('courseSelect');
            const currentCourseId = courseSelect.value;
            courseSelect.disabled = true;
            courseSelect.innerHTML = '<option value="">Завантаження...</option>';

            if (!groupId) {
                courseSelect.innerHTML = '<option value="">@Localizer["SelectGroupFirst"]</option>';
                courseSelect.disabled = true;
                return;
            }

            const response = await fetch(`/Schedules/GetCoursesByGroup?groupId=${groupId}`);
            const courses = await response.json();

            courseSelect.innerHTML = '<option value="">@Localizer["SelectCourse"]</option>';
            courses.forEach(c => {
                const selected = c.id == currentCourseId ? 'selected' : '';
                courseSelect.innerHTML += `<option value="${c.id}" ${selected}>${c.name}</option>`;
            });
            courseSelect.disabled = false;
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}