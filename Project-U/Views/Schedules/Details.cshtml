@model ProjectU.Core.Models.Schedule
@{
    ViewData["Title"] = "Деталі розкладу";
}

<h2>Деталі розкладу</h2>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Курс</dt>
            <dd class="col-sm-9">@(Model?.Course?.Name ?? "—")</dd>

            <dt class="col-sm-3">Група</dt>
            <dd class="col-sm-9"><span class="badge bg-secondary">@(Model?.Group?.Name ?? "—")</span></dd>

            <dt class="col-sm-3">Час початку</dt>
            <dd class="col-sm-9">@Model?.StartTime.ToString("HH:mm")</dd>

            <dt class="col-sm-3">Час завершення</dt>
            <dd class="col-sm-9">@Model?.EndTime.ToString("HH:mm")</dd>

            <dt class="col-sm-3">Аудиторія</dt>
            <dd class="col-sm-9">
                @if (!string.IsNullOrEmpty(Model?.Room))
                {
                    @if (Model.Room.StartsWith("http"))
                    {
                        <a href="@Model.Room" target="_blank" class="btn btn-sm btn-outline-info">🔗 Онлайн</a>
                    }
                    else
                    {
                        <span>🏫 @Model.Room</span>
                    }
                }
                else
                {
                    <span class="text-muted">—</span>
                }
            </dd>

            <dt class="col-sm-3">Дати занять</dt>
            <dd class="col-sm-9">
                @if (Model?.Dates != null && Model.Dates.Any())
                {
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var date in Model.Dates.OrderBy(d => d.Date))
                        {
                            <span class="badge bg-primary">@date.Date.ToString("dd.MM.yyyy")</span>
                        }
                    </div>
                }
                else
                {
                    <span class="text-muted">Дати не вказані</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">✏️ Редагувати</a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger">🗑️ Видалити</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</div>