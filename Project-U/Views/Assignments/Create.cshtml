@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Assignment
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>➕ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">@Localizer["AssignmentTitle"]</label>
                        <input asp-for="Title" class="form-control" placeholder="@Localizer["AssignmentTitlePlaceholder"]" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">@Localizer["Description"]</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="@Localizer["DescriptionPlaceholder"]"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Deadline" class="form-label">@Localizer["Deadline"]</label>
                        <input asp-for="Deadline" class="form-control" type="datetime-local" />
                        <span asp-validation-for="Deadline" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CourseId" class="form-label">@Localizer["Course"]</label>
                        <select asp-for="CourseId" asp-items="ViewBag.CourseId" class="form-select">
                            <option value="">@Localizer["SelectCourse"]</option>
                        </select>
                        <span asp-validation-for="CourseId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">📎 @Localizer["Material"]</label>
                        <select id="materialType" name="MaterialType" class="form-select" onchange="toggleMaterial(this.value)">
                            <option value="None">@Localizer["NoMaterial"]</option>
                            <option value="Link">🔗 @Localizer["Link"]</option>
                            <option value="File">📄 @Localizer["File"]</option>
                        </select>
                    </div>

                    <div id="materialLink" class="mb-3" style="display:none">
                        <label class="form-label">@Localizer["LinkUrl"]</label>
                        <input type="url" name="MaterialUrl" class="form-control" placeholder="@Localizer["LinkPlaceholder"]" />
                    </div>

                    <div id="materialFile" class="mb-3" style="display:none">
                        <label class="form-label">@Localizer["NewFile"]</label>
                        <input type="file" name="materialFile" class="form-control" accept=".pdf,.docx" />
                        <div class="form-check mt-2">
                            <input type="checkbox" name="AllowDownload" value="true" class="form-check-input" id="allowDownload" checked />
                            <label class="form-check-label" for="allowDownload">@Localizer["AllowDownload"]</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">➕ @Localizer["Create"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleMaterial(value) {
            document.getElementById('materialLink').style.display = value === 'Link' ? 'block' : 'none';
            document.getElementById('materialFile').style.display = value === 'File' ? 'block' : 'none';
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}