@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"].Value;
    var grouped = ViewBag.GroupedAssignments as IEnumerable<dynamic>;
    var currentUserId = ViewBag.CurrentUserId as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 @Localizer["Title"]</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Create" class="btn btn-primary">➕ @Localizer["AddAssignment"]</a>
    }
</div>

<!-- Фільтр по курсу -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center flex-wrap">
            <label class="form-label mb-0">📚 @Localizer["FilterByCourse"]:</label>
            <select name="courseId" class="form-select" style="max-width: 250px;" onchange="this.form.submit()">
                <option value="">@Localizer["AllCourses"]</option>
                @foreach (var course in ViewBag.Courses as List<ProjectU.Core.Models.Course>)
                {
                    <option value="@course.Id" selected="@(ViewBag.SelectedCourseId != null && ViewBag.SelectedCourseId.ToString() == course.Id.ToString())">
                        @course.Name
                    </option>
                }
            </select>
            @if (ViewBag.SelectedCourseId != null)
            {
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✕ @Localizer["Reset"]</a>
            }
        </form>
    </div>
</div>

@if (grouped != null && grouped.Any())
{
    @foreach (var group in grouped)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>📚 @group.CourseName</strong>
                    <span class="text-muted small ms-2">
                        @((group.Assignments as IEnumerable<dynamic>)?.Count() ?? 0) @Localizer["Title"].Value.ToLower()
                    </span>
                </div>
                <div class="d-flex gap-1">
                    @if ((bool)group.HasExpired)
                    {
                        <span class="badge bg-danger">❌ @Localizer["Expired"]</span>
                    }
                    @if ((bool)group.HasUrgent)
                    {
                        <span class="badge bg-warning">⚠️ @Localizer["Urgent"]</span>
                    }
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (ProjectU.Core.Models.Assignment item in group.Assignments)
                    {
                        var isExpired = item.Deadline < DateTime.Now;
                        var hoursLeft = (item.Deadline - DateTime.Now).TotalHours;
                        var borderColor = isExpired ? "#d63031" : hoursLeft < 24 ? "#fdcb6e" : "#00b894";
                        var statusEmoji = isExpired ? "❌" : hoursLeft < 24 ? "⚠️" : "✅";
                        var mySubmission = item.Submissions?.FirstOrDefault(s => s.StudentId == currentUserId);
                        var submissionsCount = item.Submissions?.Count ?? 0;

                        <div class="col-md-6 mb-3">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none d-block">
                                <div class="card h-100" style="border-top: 3px solid @borderColor; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease;"
                                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.15)'"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="mb-0">@item.Title</h6>
                                            <span style="font-size:1.3rem;">@statusEmoji</span>
                                        </div>

                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="small text-muted mb-2" style="overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                                @item.Description
                                            </p>
                                        }

                                        @if (item.MaterialType != "None")
                                        {
                                            <div class="mb-2">
                                                @if (item.MaterialType == "Link")
                                                {
                                                    <span class="badge bg-info">🔗 @Localizer["HasMaterialLink"]</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">📄 @Localizer["HasMaterialFile"]</span>
                                                }
                                            </div>
                                        }

                                        <div class="mb-1">
                                            <small class="text-muted">⏰ @Localizer["Deadline"]:</small>
                                            <span class="badge fs-6 text-white" style="background: @borderColor;">
                                                @item.Deadline.ToString("dd.MM.yyyy HH:mm")
                                                @if (isExpired)
                                                {
                                                    <text>(@Localizer["Overdue"])</text>
                                                }
                                                else if (hoursLeft < 24)
                                                {

                                                    <text>(@Localizer["HoursLeft"] @((int)hoursLeft) @Localizer["Hours"])</text>
                                                }
                                            </span>
                                        </div>

                                        <div class="mt-2">
                                            @if (User.IsInRole("Student"))
                                            {
                                                @if (mySubmission != null)
                                                {
                                                    @if (mySubmission.IsGraded)
                                                    {
                                                        <span class="badge bg-success">✅ @Localizer["SubmittedGraded"]</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning">⏳ @Localizer["SubmittedWaiting"]</span>
                                                    }
                                                }
                                                else if (!isExpired)
                                                {
                                                    <span class="badge bg-danger">📤 @Localizer["NotSubmitted"]</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">❌ @Localizer["NotSubmittedExpired"]</span>
                                                }
                                            }
                                            else if (User.IsInRole("Teacher") || User.IsInRole("Admin"))
                                            {
                                                var gradedCount = item.Submissions?.Count(s => s.IsGraded) ?? 0;
                                                <span class="badge bg-secondary">📤 @Localizer["Submissions"]: @submissionsCount</span>
                                                <span class="badge bg-success ms-1">✅ @Localizer["Graded"]: @gradedCount</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info text-center p-4">
        <div style="font-size: 3rem;">📭</div>
        <div>@Localizer["NoAssignments"]</div>
    </div>
}