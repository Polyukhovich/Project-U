@{
    ViewData["Title"] = "Завдання";
    var grouped = ViewBag.GroupedAssignments as IEnumerable<dynamic>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Завдання</h2>
    @if (User.IsInRole("Admin") || User.IsInRole("Teacher"))
    {
        <a asp-action="Create" class="btn btn-primary">➕ Створити завдання</a>
    }
</div>

@if (grouped != null && grouped.Any())
{
    @foreach (var group in grouped)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>📚 @group.CourseName</strong>
                    <span class="text-muted small ms-2">
                        @((group.Assignments as IEnumerable<dynamic>)?.Count() ?? 0) завдань
                    </span>
                </div>
                <div class="d-flex gap-1">
                    @if ((bool)group.HasExpired)
                    {
                        <span class="badge bg-danger">❌ Є прострочені</span>
                    }
                    @if ((bool)group.HasUrgent)
                    {
                        <span class="badge bg-warning">⚠️ Є термінові</span>
                    }
                </div>
            </div>

            <div class="card-body">
                <div class="row">
                    @foreach (ProjectU.Core.Models.Assignment item in group.Assignments)
                    {
                        var isExpired = item.Deadline < DateTime.Now;
                        var hoursLeft = (item.Deadline - DateTime.Now).TotalHours;
                        var borderColor = isExpired ? "#d63031" : hoursLeft < 24 ? "#fdcb6e" : "#00b894";
                        var statusEmoji = isExpired ? "❌" : hoursLeft < 24 ? "⚠️" : "✅";

                        <div class="col-md-6 mb-3">
                            <!-- Клікабельна картка -->
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none d-block">
                                <div class="card"
                                     style="border-top: 3px solid @borderColor; cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease;"
                                     onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 10px 25px rgba(0,0,0,0.15)'"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow=''">

                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h6 class="mb-0 text-dark">@item.Title</h6>
                                            <span style="font-size:1.3rem;">@statusEmoji</span>
                                        </div>

                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="small text-muted mb-2" style="overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                                @item.Description
                                            </p>
                                        }

                                        @if (item.MaterialType != "None")
                                        {
                                            <div class="mb-2">
                                                @if (item.MaterialType == "Link")
                                                {
                                                    <span class="badge bg-info">🔗 Є посилання</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-info">📄 Є файл</span>
                                                }
                                            </div>
                                        }

                                        <div class="mb-1">
                                            <small class="text-muted">📅 Створено: @item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                        </div>

                                        <div class="mb-1">
                                            <small class="text-muted">⏰ Дедлайн:</small>
                                            <span class="badge fs-6 text-white" style="background: @borderColor;">
                                                @item.Deadline.ToString("dd.MM.yyyy HH:mm")
                                                @if (isExpired)
                                                {
                                                    <text> (прострочено)</text>
                                                }
                                                else if (hoursLeft < 24)
                                                {
                                                    <text> (залишилось @((int)hoursLeft) год)</text>
                                                }
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="alert alert-info text-center p-4">
        <div style="font-size: 3rem;">📭</div>
        <div>Завдань ще немає</div>
    </div>
}