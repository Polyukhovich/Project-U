@model ProjectU.Core.Models.Assignment
@{
    ViewData["Title"] = "Видалити завдання";
    var isExpired = Model.Deadline < DateTime.Now;
    var borderColor = isExpired ? "#d63031" : "#00b894";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ Видалити завдання</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ Ви впевнені що хочете видалити це завдання? Всі здачі студентів також будуть видалені!
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-4">Назва</dt>
                    <dd class="col-sm-8"><strong>@Model.Title</strong></dd>

                    <dt class="col-sm-4">Курс</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@(Model.Course?.Name ?? "—")</span>
                    </dd>

                    <dt class="col-sm-4">Дедлайн</dt>
                    <dd class="col-sm-8">
                        <span class="badge" style="background: @borderColor;">
                            @Model.Deadline.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    </dd>

                    <dt class="col-sm-4">Здачі</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@(Model.Submissions?.Count ?? 0)</span>
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ Видалити</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>