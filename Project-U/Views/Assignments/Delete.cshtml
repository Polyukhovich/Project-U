@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.Assignment
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var isExpired = Model.Deadline < DateTime.Now;
    var borderColor = isExpired ? "#d63031" : "#00b894";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                <div class="alert alert-warning mb-3">
                    ⚠️ @Localizer["Warning"]
                </div>
                <dl class="row mb-3">
                    <dt class="col-sm-4">@Localizer["Name"]</dt>
                    <dd class="col-sm-8"><strong>@Model.Title</strong></dd>

                    <dt class="col-sm-4">@Localizer["Course"]</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@(Model.Course?.Name ?? "—")</span>
                    </dd>

                    <dt class="col-sm-4">@Localizer["Deadline"]</dt>
                    <dd class="col-sm-8">
                        <span class="badge" style="background: @borderColor;">
                            @Model.Deadline.ToString("dd.MM.yyyy HH:mm")
                            @if (isExpired)
                            {
                                <text>(@Localizer["Overdue"])</text>
                            }
                        </span>
                    </dd>

                    <dt class="col-sm-4">@Localizer["Submissions"]</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-secondary">@(Model.Submissions?.Count ?? 0)</span>
                    </dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger flex-fill">🗑️ @Localizer["Delete"]</button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>