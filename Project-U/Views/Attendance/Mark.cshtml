@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var schedule = ViewBag.Schedule as ProjectU.Core.Models.Schedule;
    var date = (DateOnly)ViewBag.Date;
    var existing = ViewBag.Existing as List<ProjectU.Core.Models.Attendance>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📅 @Localizer["Title"]</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← @Localizer["Back"]</a>
</div>

<div class="card">
    <div class="card-header">
        <strong>📚 @schedule?.Course?.Name</strong>
        <span class="text-muted ms-2">@date.ToString("dd.MM.yyyy")</span>
    </div>
    <div class="card-body">
        <form asp-action="Mark" method="post">
            <input type="hidden" name="scheduleId" value="@schedule?.Id" />
            <input type="hidden" name="date" value="@date" />

            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>👤 @Localizer["Student"]</th>
                            <th>✅ @Localizer["Present"]</th>
                            <th>💬 @Localizer["Comment"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in schedule?.Group?.Students ?? new List<ProjectU.Core.Models.ApplicationUser>())
                        {
                            var existingRecord = existing?.FirstOrDefault(a => a.StudentId == student.Id);
                            var isPresent = existingRecord?.IsPresent ?? true;

                            <input type="hidden" name="studentIds" value="@student.Id" />
                            <tr>
                                <td>@student.FirstName @student.LastName</td>
                                <td>
                                    <div class="form-check form-switch">
                                        <input type="checkbox" name="presentIds"
                                               value="@student.Id"
                                               class="form-check-input"
                                               @(isPresent ? "checked" : "") />
                                    </div>
                                </td>
                                <td>
                                    <input type="text" name="comments[@student.Id]"
                                           class="form-control form-control-sm"
                                           value="@existingRecord?.Comment"
                                           placeholder="@Localizer["CommentPlaceholder"]" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">💾 @Localizer["Save"]</button>
                <a asp-action="Index" class="btn btn-outline-secondary">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>