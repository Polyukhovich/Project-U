@model ProjectU.Core.Models.Group
@{
    ViewData["Title"] = "Редагувати групу";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>✏️ Редагувати групу</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row">
    <div class="col-md-5">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Назва групи</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-fill">💾 Зберегти</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}