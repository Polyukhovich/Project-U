@model ProjectU.Core.Models.Group
@{
    ViewData["Title"] = "Видалити групу";
}

<h2>Видалити групу</h2>

<div class="alert alert-warning">
    ⚠️ Ви впевнені що хочете видалити цю групу?
</div>

@if (ViewBag.HasStudents == true)
{
    <div class="alert alert-danger">
        ❌ Неможливо видалити групу <strong>@Model.Name</strong> — в ній є студенти!
        Спочатку перемістіть або видаліть студентів групи.
    </div>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
}
else
{
    <dl class="row">
        <dt class="col-sm-3">Назва групи</dt>
        <dd class="col-sm-9">@Model.Name</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <button type="submit" class="btn btn-danger">🗑️ Видалити</button>
        <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
    </form>
}