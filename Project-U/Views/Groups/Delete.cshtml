@model ProjectU.Core.Models.Group
@{
    ViewData["Title"] = "Видалити групу";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🗑️ Видалити групу</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Назад</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-body">
                @if (ViewBag.HasStudents == true)
                {
                    <div class="alert alert-danger mb-3">
                        ❌ Неможливо видалити групу <strong>@Model.Name</strong> — в ній є студенти!
                        Спочатку перемістіть або видаліть студентів групи.
                    </div>
                    <a asp-action="Index" class="btn btn-secondary w-100">← Назад</a>
                }
                else
                {
                    <div class="alert alert-warning mb-3">
                        ⚠️ Ви впевнені що хочете видалити цю групу?
                    </div>

                    <dl class="row mb-3">
                        <dt class="col-sm-4">Назва групи</dt>
                        <dd class="col-sm-8"><strong>@Model.Name</strong></dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger flex-fill">🗑️ Видалити</button>
                            <a asp-action="Index" class="btn btn-outline-secondary flex-fill">Скасувати</a>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>
</div>