@model ProjectU.Core.Models.ApplicationUser
@{
    ViewData["Title"] = "Налаштування";
}

<h2 class="mb-4">⚙️ Налаштування</h2>

<div class="row">
    <!-- Акаунт -->
    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header">👤 Акаунт</div>
            <div class="card-body">
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary w-100 mb-2">✏️ Редагувати профіль</a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-outline-warning w-100">🔑 Змінити пароль</a>
            </div>
        </div>
    </div>

    <!-- Мова -->
    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header">🌐 Мова інтерфейсу</div>
            <div class="card-body">
                <form asp-controller="SelectLanguage" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="returnUrl" value="/Settings" />
                    <div class="d-grid gap-2">
                        <button type="submit" name="cultureName" value="uk-UA" class="btn btn-outline-primary">🇺🇦 Українська</button>
                        <button type="submit" name="cultureName" value="en-US" class="btn btn-outline-secondary">🇺🇸 English</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Тема -->
    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header">🎨 Тема оформлення</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <button onclick="setTheme('default')" class="btn btn-sm btn-outline-secondary">⚪ Стандартна</button>
                    <button onclick="setTheme('dark')" class="btn btn-sm btn-dark">🌙 Темна</button>
                    <button onclick="setTheme('green')" class="btn btn-sm btn-success">💚 Зелена</button>
                    <button onclick="setTheme('blue')" class="btn btn-sm btn-primary">💙 Синя</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Вихід -->
    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-header text-danger">⚠️ Небезпечна зона</div>
            <div class="card-body">
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="btn btn-danger w-100">🚪 Вийти з акаунту</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/theme.js"></script>
}