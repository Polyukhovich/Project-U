@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.ApplicationUser
@{
    ViewData["Title"] = Localizer["Title"].Value;
}

<h2 class="mb-4">⚙️ @Localizer["Title"]</h2>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header">👤 @Localizer["Account"]</div>
            <div class="card-body">
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary w-100 mb-2">✏️ @Localizer["EditProfile"]</a>
                <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-outline-warning w-100">🔑 @Localizer["ChangePassword"]</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header">🌐 @Localizer["Language"]</div>
            <div class="card-body">
                <form asp-controller="SelectLanguage" asp-action="SetLanguage" method="post">
                    <input type="hidden" name="returnUrl" value="/Settings" />
                    <div class="d-grid gap-2">
                        <button type="submit" name="cultureName" value="uk-UA" class="btn btn-outline-primary">🇺🇦 Українська</button>
                        <button type="submit" name="cultureName" value="en-US" class="btn btn-outline-secondary">🇺🇸 English</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid var(--accent);">
            <div class="card-header">🎨 @Localizer["Theme"]</div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2">
                    <button onclick="setTheme('default')" class="btn btn-sm btn-outline-secondary">⚪ @Localizer["Default"]</button>
                    <button onclick="setTheme('dark')" class="btn btn-sm btn-dark">🌙 @Localizer["Dark"]</button>
                    <button onclick="setTheme('green')" class="btn btn-sm btn-success">💚 @Localizer["Green"]</button>
                    <button onclick="setTheme('blue')" class="btn btn-sm btn-primary">💙 @Localizer["Blue"]</button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card" style="border-top: 4px solid #d63031;">
            <div class="card-header text-danger">⚠️ @Localizer["DangerZone"]</div>
            <div class="card-body">
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="btn btn-danger w-100">🚪 @Localizer["Logout"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/theme.js"></script>
}