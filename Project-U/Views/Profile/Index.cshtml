@model ProjectU.Core.Models.ApplicationUser
@{
    ViewData["Title"] = "Профіль";
    var role = ViewBag.Role as string ?? "Student";
    var initials = $"{Model?.FirstName?.FirstOrDefault()}{Model?.LastName?.FirstOrDefault()}";
}
<!-- Шапка профілю -->
<div class="card mb-4">
    <div class="card-body d-flex align-items-center gap-4 p-4 flex-wrap">
        <div class="avatar">@initials</div>
        <div>
            <h3 class="mb-1">@Model?.FirstName @Model?.LastName</h3>
            <p class="text-muted mb-1">@Model?.Email</p>
            @if (role == "Student")
            {
                <span class="badge bg-primary">👨‍🎓 Студент</span>
                <span class="badge bg-secondary ms-1">@(Model?.Group?.Name ?? "Без групи")</span>
            }
            else if (role == "Teacher")
            {
                <span class="badge bg-success">👨‍🏫 Викладач</span>
            }
            else if (role == "Admin")
            {
                <span class="badge bg-danger">⚙️ Адміністратор</span>
            }
        </div>
        <div class="ms-auto">
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary btn-sm">✏️ Редагувати</a>
            <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-outline-warning btn-sm ms-1">🔑 Пароль</a>
        </div>
    </div>
</div>

<!-- Студент -->
@if (role == "Student")
{
    var grades = ViewBag.Grades as List<ProjectU.Core.Models.Grade>;
    var labWorks = ViewBag.LabWorks as List<ProjectU.Core.Models.LabWork>;
    var avgGrade = grades != null && grades.Any() ? grades.Average(g => g.Value) : 0;

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="stat-number">@(grades?.Count ?? 0)</div>
                <div class="stat-label">📊 Оцінок</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #00b894, #55efc4);">
                <div class="stat-number">@avgGrade.ToString("F1")</div>
                <div class="stat-label">⭐ Середній бал</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #0984e3, #74b9ff);">
                <div class="stat-number">@(labWorks?.Count ?? 0)</div>
                <div class="stat-label">🔬 Зданих робіт</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">📊 Останні оцінки</div>
                <div class="card-body p-0">
                    @if (grades != null && grades.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr><th>Курс</th><th>Оцінка</th><th>Дата</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var grade in grades)
                                {
                                    <tr onclick="window.location='/Grades/Details/@grade.Id'" style="cursor:pointer;">
                                        <td>@grade.Course?.Name</td>
                                        <td>
                                            <span class="badge @(grade.Value >= 90 ? "bg-success" : grade.Value >= 60 ? "bg-warning" : "bg-danger")">
                                                @grade.Value
                                            </span>
                                        </td>
                                        <td>@grade.CreatedAt.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">Оцінок ще немає</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">🔬 Останні роботи</div>
                <div class="card-body p-0">
                    @if (labWorks != null && labWorks.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr><th>Завдання</th><th>Дата</th><th>Статус</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var work in labWorks)
                                {
                                    <tr onclick="window.location='/LabWorks/Details/@work.Id'" style="cursor:pointer;">
                                        <td>@work.Assignment?.Title</td>
                                        <td>@work.UploadedAt.ToShortDateString()</td>
                                        <td>
                                            @if (work.IsGraded)
                                            {
                                                <span class="badge bg-success">✅ Оцінено</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">⏳ Очікує</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">Робіт ще немає</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Викладач -->
@if (role == "Teacher")
{
    var courses = ViewBag.Courses as List<ProjectU.Core.Models.Course>;
    var assignments = ViewBag.Assignments as List<ProjectU.Core.Models.Assignment>;

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="stat-number">@(courses?.Count ?? 0)</div>
                <div class="stat-label">📚 Курсів</div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #00b894, #55efc4);">
                <div class="stat-number">@(assignments?.Count ?? 0)</div>
                <div class="stat-label">📋 Завдань</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">📚 Мої курси</div>
                <div class="card-body p-0">
                    @if (courses != null && courses.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Курс</th><th>Група</th></tr></thead>
                            <tbody>
                                @foreach (var course in courses)
                                {
                                    <tr onclick="window.location='/Courses/Details/@course.Id'" style="cursor:pointer;">
                                        <td>@course.Name</td>
                                        <td><span class="badge bg-secondary">@course.Group?.Name</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">Курсів ще немає</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">📋 Останні завдання</div>
                <div class="card-body p-0">
                    @if (assignments != null && assignments.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Завдання</th><th>Дедлайн</th></tr></thead>
                            <tbody>
                                @foreach (var assignment in assignments)
                                {
                                    <tr onclick="window.location='/Assignments/Details/@assignment.Id'" style="cursor:pointer;">
                                        <td>@assignment.Title</td>
                                        <td>
                                            <span class="badge @(assignment.Deadline < DateTime.Now ? "bg-danger" : "bg-success")">
                                                @assignment.Deadline.ToShortDateString()
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">Завдань ще немає</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Адмін -->
@if (role == "Admin")
{
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="stat-number">@ViewBag.TotalUsers</div>
                <div class="stat-label">👥 Користувачів</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #00b894, #55efc4);">
                <div class="stat-number">@ViewBag.TotalCourses</div>
                <div class="stat-label">📚 Курсів</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #0984e3, #74b9ff);">
                <div class="stat-number">@ViewBag.TotalGroups</div>
                <div class="stat-label">👥 Груп</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #e17055, #fab1a0);">
                <div class="stat-number">@ViewBag.TotalLabWorks</div>
                <div class="stat-label">🔬 Робіт</div>
            </div>
        </div>
    </div>
}