@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@model ProjectU.Core.Models.ApplicationUser
@{
    ViewData["Title"] = Localizer["Title"].Value;
    var role = ViewBag.Role as string ?? "Student";
    var initials = $"{Model?.FirstName?.FirstOrDefault()}{Model?.LastName?.FirstOrDefault()}";
}

<!-- Шапка профілю -->
<div class="card mb-4">
    <div class="card-body d-flex align-items-center gap-4 p-4 flex-wrap">
        <div class="avatar">@initials</div>
        <div>
            <h3 class="mb-1">@Model?.FirstName @Model?.LastName</h3>
            <p class="text-muted mb-1">@Model?.Email</p>
            @if (role == "Student")
            {
                <span class="badge bg-primary">👨‍🎓 @Localizer["Student"]</span>
                <span class="badge bg-secondary ms-1">@(Model?.Group?.Name ?? Localizer["NoGroup"].Value)</span>
            }
            else if (role == "Teacher")
            {
                <span class="badge bg-success">👨‍🏫 @Localizer["Teacher"]</span>
            }
            else if (role == "Admin")
            {
                <span class="badge bg-danger">⚙️ @Localizer["Admin"]</span>
            }
        </div>
        <div class="ms-auto">
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-outline-primary btn-sm">✏️ @Localizer["Edit"]</a>
            <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-outline-warning btn-sm ms-1">🔑 @Localizer["Password"]</a>
        </div>
    </div>
</div>

<!-- Студент -->
@if (role == "Student")
{
    var grades = ViewBag.Grades as List<ProjectU.Core.Models.Grade>;
    var labWorks = ViewBag.LabWorks as List<ProjectU.Core.Models.LabWork>;
    var avgGrade = grades != null && grades.Any() ? grades.Average(g => g.Value) : 0;

    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="stat-number">@(grades?.Count ?? 0)</div>
                <div class="stat-label">📊 @Localizer["GradesCount"]</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #00b894, #55efc4);">
                <div class="stat-number">@avgGrade.ToString("F1")</div>
                <div class="stat-label">⭐ @Localizer["AverageGrade"]</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #0984e3, #74b9ff);">
                <div class="stat-number">@(labWorks?.Count ?? 0)</div>
                <div class="stat-label">🔬 @Localizer["WorksCount"]</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">📊 @Localizer["RecentGrades"]</div>
                <div class="card-body p-0">
                    @if (grades != null && grades.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["Course"]</th>
                                    <th>@Localizer["Grade"]</th>
                                    <th>@Localizer["Date"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var grade in grades)
                                {
                                    <tr onclick="window.location='/Grades/Details/@grade.Id'" style="cursor:pointer;">
                                        <td>@grade.Course?.Name</td>
                                        <td>
                                            <span class="badge @(grade.Value >= 90 ? "bg-success" : grade.Value >= 60 ? "bg-warning" : "bg-danger")">
                                                @grade.Value
                                            </span>
                                        </td>
                                        <td>@grade.CreatedAt.ToShortDateString()</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">@Localizer["NoGrades"]</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header">🔬 @Localizer["RecentWorks"]</div>
                <div class="card-body p-0">
                    @if (labWorks != null && labWorks.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["Assignment"]</th>
                                    <th>@Localizer["Date"]</th>
                                    <th>@Localizer["Status"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var work in labWorks)
                                {
                                    <tr onclick="window.location='/LabWorks/Details/@work.Id'" style="cursor:pointer;">
                                        <td>@work.Assignment?.Title</td>
                                        <td>@work.UploadedAt.ToShortDateString()</td>
                                        <td>
                                            @if (work.IsGraded)
                                            {
                                                <span class="badge bg-success">✅ @Localizer["Graded"]</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning">⏳ @Localizer["Waiting"]</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">@Localizer["NoWorks"]</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Викладач -->
@if (role == "Teacher")
{
    var courses = ViewBag.Courses as List<ProjectU.Core.Models.Course>;
    var assignments = ViewBag.Assignments as List<ProjectU.Core.Models.Assignment>;

    <div class="row mb-4">
        <div class="col-md-6 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="stat-number">@(courses?.Count ?? 0)</div>
                <div class="stat-label">📚 @Localizer["CoursesCount"]</div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #00b894, #55efc4);">
                <div class="stat-number">@(assignments?.Count ?? 0)</div>
                <div class="stat-label">📋 @Localizer["AssignmentsCount"]</div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">📚 @Localizer["MyCourses"]</div>
                <div class="card-body p-0">
                    @if (courses != null && courses.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["Course"]</th>
                                    <th>@Localizer["Group"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in courses)
                                {
                                    <tr onclick="window.location='/Courses/Details/@course.Id'" style="cursor:pointer;">
                                        <td>@course.Name</td>
                                        <td><span class="badge bg-secondary">@course.Group?.Name</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">@Localizer["NoCourses"]</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header">📋 @Localizer["RecentAssignments"]</div>
                <div class="card-body p-0">
                    @if (assignments != null && assignments.Any())
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>@Localizer["Assignment"]</th>
                                    <th>@Localizer["Deadline"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var assignment in assignments)
                                {
                                    <tr onclick="window.location='/Assignments/Details/@assignment.Id'" style="cursor:pointer;">
                                        <td>@assignment.Title</td>
                                        <td>
                                            <span class="badge @(assignment.Deadline < DateTime.Now ? "bg-danger" : "bg-success")">
                                                @assignment.Deadline.ToShortDateString()
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 text-center">@Localizer["NoAssignments"]</p>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Адмін -->
@if (role == "Admin")
{
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="stat-number">@ViewBag.TotalUsers</div>
                <div class="stat-label">👥 @Localizer["UsersCount"]</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #00b894, #55efc4);">
                <div class="stat-number">@ViewBag.TotalCourses</div>
                <div class="stat-label">📚 @Localizer["CoursesCount"]</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #0984e3, #74b9ff);">
                <div class="stat-number">@ViewBag.TotalGroups</div>
                <div class="stat-label">👥 @Localizer["GroupsCount"]</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card" style="background: linear-gradient(135deg, #e17055, #fab1a0);">
                <div class="stat-number">@ViewBag.TotalLabWorks</div>
                <div class="stat-label">🔬 @Localizer["WorksCount"]</div>
            </div>
        </div>
    </div>
}